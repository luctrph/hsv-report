<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="hach_toan_luong" pageWidth="1080" pageHeight="709" orientation="Landscape" columnWidth="1080" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="f36939f8-610e-4105-80ec-11593e266e7b">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.rows" value="true"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.columns" value="true"/>
	<property name="net.sf.jasperreports.export.xls.ignore.cell.border" value="false"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="psql"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="0"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="1000"/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageHeight" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.pageWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.topMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.bottomMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.leftMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.rightMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnSpacing" value="pixel"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="C_Period_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="C_DocType_ID" class="java.lang.Integer"/>
	<parameter name="GL_Category_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[WITH p AS (
  SELECT startdate as period_startdate,
  			enddate as period_enddate
  FROM c_period
  WHERE c_period_id = $P{C_Period_ID}
    AND ad_client_id = $P{AD_CLIENT_ID}
),

dm_header as (
	SELECT 
    cp.enddate AS ngay,
    tye.name   AS c_type,
    org.name   AS org_name,
    sche.name  AS sche_name,
    gl.name    AS gl_name
	FROM c_period cp
	CROSS JOIN C_DocType tye
	CROSS JOIN C_AcctSchema sche
	CROSS JOIN GL_Category gl
	LEFT JOIN AD_Org org 
	       ON org.ad_org_id = $P{AD_Org_ID}
	      AND org.ad_client_id = $P{AD_CLIENT_ID}
	WHERE cp.ad_client_id = $P{AD_CLIENT_ID}
	  AND cp.c_period_id  = $P{C_Period_ID}
	  AND tye.c_doctype_id = $P{C_DocType_ID}
	  AND sche.ad_client_id = $P{AD_CLIENT_ID}
	  AND gl.GL_Category_ID = $P{GL_Category_ID}
	  AND ($P{AD_Org_ID} IS NULL OR org.ad_org_id IS NOT NULL)
),
dm_chi_tiet as (
SELECT row_number() over(order by lb.hsv_luongbep_id)*10 as stt,
    org.name AS org,
    lb.hsv_cotluong,
    lb.name AS cotluong,
    cb.value AS doitac,
    cb.name  AS doitac_name,
    ce.value AS tk,
    ac.value AS hoatdong,
    lb.c_currency_id AS currency
FROM hsv_luongbep lb
JOIN ad_org org 
     ON org.ad_org_id = lb.ad_org_id 
JOIN c_bpartner cb 
     ON cb.c_bpartner_id = lb.c_bpartner_id  
JOIN c_elementvalue ce 
     ON ce.c_elementvalue_id = lb.account_id 
JOIN c_activity ac 
     ON ac.c_activity_id = lb.c_activity_id 
WHERE lb.ad_client_id = $P{AD_CLIENT_ID}
  AND lb.hsv_cotluong IN ('tru_bhxh','tru_anca','tru_congdoan','luong_conlai','luong','ht_anca','ht_bhxh','luong_ck','TRU_TTNCN')

 ),

tong_luong as (
		select nkl.hsv_toluong_id,sum(nklsp.amount) as tongluong 
		from hsv_nkluongsp nklsp
		left join hsv_nkluong nkl on nkl.hsv_nkluong_id = nklsp.hsv_nkluong_id 			
		where nkl.c_period_id = $P{C_Period_ID} and nklsp.isactive = 'Y' and nkl.isactive = 'Y'
		group by nkl.hsv_toluong_id
),
tong_cong as (
		select nkl.hsv_toluong_id, sum(nklnv.hsv_ngaycong* nklnv.hsv_hesoluong) as tongcong 
		from hsv_nkluongnv nklnv
		left join hsv_nkluong nkl on nkl.hsv_nkluong_id = nklnv.hsv_nkluong_id 
		where nkl.c_period_id = $P{C_Period_ID} and nklnv.isactive = 'Y' and nkl.isactive = 'Y'		
		group by nkl.hsv_toluong_id 
),
che_do as (
	select tl.hsv_toluong_id ,
		coalesce(hsv_maxHTBHXH,0) as hsv_maxHTBHXH,
		coalesce(cdl.hsv_ht_anca,0) hsv_ht_anca,
		coalesce(cdl.hsv_muc_tc2,0) hsv_muc_tc2,
		coalesce(cdl.hsv_muc_tc3,0) hsv_muc_tc3,
		coalesce(cdl.hsv_bddem,0) hsv_bddem,
		coalesce(cdl.hsv_tlbhxh,0) hsv_tlbhxh, coalesce(cdl.hsv_tlkpcd,0) hsv_tlkpcd,
		coalesce(cdl.hsv_max_kpcd,0) hsv_max_kpcd ,
		coalesce(cdl.hsv_muc_anca,0) hsv_muc_anca,
		coalesce(cdl.hsv_andem,0) hsv_andem,
		coalesce(cdl.hsv_antangca2,0) hsv_antangca2, 
		coalesce(cdl.hsv_antangca3,0) hsv_antangca3, 	
		coalesce(cdl.hsv_tlhtbhxh,0) hsv_tlhtbhxh
		from hsv_chedo cd 		
		left join hsv_cd_luong cdl on cd.hsv_chedo_id = cdl.hsv_chedo_id and cdl.isactive = 'Y'
		left join hsv_toluong tl on tl.hsv_chedo_id = cd.hsv_chedo_id and tl.isactive = 'Y'
		cross join p pd 
		where  pd.period_enddate <= cdl.dateto AND pd.period_enddate >= cdl.datefrom
                AND pd.period_startdate >= cdl.datefrom AND pd.period_startdate <= cdl.dateto			
				and cd.isactive = 'Y'
),
chuyen_khoan as (
	select vck.hsv_nhanvien_id,vck.hsv_toluong_id, coalesce(vck.hsv_ckluong,0)  as luongck
	from hsv_chuyenkhoan vck 
	cross join p pd 
	where pd.period_enddate <= vck.dateto AND pd.period_enddate >= vck.datefrom
                AND pd.period_startdate >= vck.datefrom AND pd.period_startdate <= vck.dateto		
	and vck.ad_client_id =$P{AD_CLIENT_ID} and vck.isactive = 'Y'

),
luong_cung as (
	select lc.hsv_toluong_id, lc.hsv_nhanvien_id as a1,
		coalesce(hsv_phucap,0) as hsv_phucap,
		coalesce(hsv_luongcd,0) as hsv_luongcd,
		coalesce(hsv_maxcong,0) as hsv_maxcong,
		coalesce(congmax,0) as congmax   
	from hsv_luongcung lc
	cross join p pd 
	where pd.period_enddate <= lc.dateto AND pd.period_enddate >= lc.datefrom
                AND pd.period_startdate >= lc.datefrom AND pd.period_startdate <= lc.dateto			
	and lc.ad_client_id =$P{AD_CLIENT_ID}  and lc.isactive = 'Y'	
),
chi_tiet_luong_bhxh as (
	select b.ad_org_id,
		case when  a.hsv_luongbhxh > b.hsv_luongbhxh then a.hsv_luongbhxh else 0 end as hsv_luongbhxh,
		case when  a.hsv_luongbhxh > b.hsv_luongbhxh then a.hsv_htbhxh end as hsv_htbhxh,
	    b.hsv_toluong_id ,
	    b.hsv_nhanvien_id ,
	    b.hsv_ngaycong as hsv_ngaycong,
	    b.hsv_hesoluong as hsv_hesoluong,
	    b.hsv_ngayanca as hsv_ngayanca,
	    b.hsv_ngaytangca2 as hsv_ngaytangca2,
	    b.hsv_congdem as hsv_congdem,
	    b.hsv_ckluong as hsv_ckluong,
	    b.hsv_ngaytangca3 as hsv_ngaytangca3,
	    b.hsv_luongspnv as hsv_luongspnv,
	    b.hsv_phucapnv
	    
	from (							
		select  nv.hsv_nhanvien_id, MAX(nv.hsv_ngaycong) as ngaycongk,
		coalesce(bhxh.hsv_luongbhxh,0) hsv_luongbhxh,
		bhxh.hsv_htbhxh  hsv_htbhxh						
		from hsv_nkluong nk
		join hsv_nkluongnv nv on nk.hsv_nkluong_id = nv.hsv_nkluong_id 
		join hsv_luongbhxhline bhxh on bhxh.hsv_nhanvien_id = nv.hsv_nhanvien_id and bhxh.hsv_luongbhxh >0 
		cross join p pd 
		where  nk.ad_client_id = $P{AD_CLIENT_ID} and nk.c_period_id =  $P{C_Period_ID} 
			 and pd.period_enddate <= bhxh.dateto AND pd.period_enddate >= bhxh.datefrom
             AND pd.period_startdate >= bhxh.datefrom AND pd.period_startdate <= bhxh.dateto									
        group by nv.hsv_nhanvien_id,bhxh.hsv_luongbhxh,bhxh.hsv_htbhxh											
	) as a right join (
		select  hsv_nkluongnv_id,0 as hsv_luongbhxh, nkl.ad_org_id,nkl.hsv_toluong_id,nklnv.hsv_nhanvien_id, 
				coalesce(hsv_ngaycong,0) as hsv_ngaycong,
				coalesce(nklnv.hsv_hesoluong,0) as hsv_hesoluong,
				coalesce(nklnv.hsv_ngayanca,0) as hsv_ngayanca,
				coalesce(nklnv.hsv_ngaytangca2,0) as hsv_ngaytangca2,
				coalesce(nklnv.hsv_congdem,0) as hsv_congdem,
				coalesce(nklnv.hsv_ckluong,0) as hsv_ckluong,
				coalesce(nklnv.hsv_ngaytangca3,0) as hsv_ngaytangca3,
				coalesce(nklnv.hsv_luongspnv,0) as hsv_luongspnv,
				coalesce(nklnv.hsv_phucap,0) as hsv_phucapnv
		from hsv_NkluongNV nklnv
		join hsv_nkluong nkl on nkl.hsv_nkluong_id = nklnv.hsv_nkluong_id 		  
		where  nkl.ad_client_id = $P{AD_CLIENT_ID} and nkl.c_period_id =  $P{C_Period_ID} and nklnv.isactive = 'Y' 					
	) as b on a.hsv_nhanvien_id =b.hsv_nhanvien_id and a.ngaycongk =  b.hsv_ngaycong 																
	
),

nguoi_pt as (
	select  hsv_nhanvien_id,count(hsv_nknguoipt_id) as songuoi_pt 
	from  hsv_nknguoipt npt
	cross join p pd
	where ad_client_id = $P{AD_CLIENT_ID}  
    and (pd.period_enddate <= npt.dateto or npt.dateto is null) AND pd.period_enddate >= npt.datefrom
   	AND pd.period_startdate >= npt.datefrom AND (pd.period_startdate <= npt.dateto or npt.dateto is null)		
   	and npt.isactive = 'Y'
	group by hsv_nhanvien_id 
),
chedo_tncn as (					
		select  coalesce(hsv_gtgcbt,0) as hsv_gtgcbt, coalesce(hsv_GTGCNPT,0) as hsv_GTGCNPT 
		from hsv_CDTTNCN cdtn 
		cross join p pd
		where ad_client_id = $P{AD_CLIENT_ID}
 		and pd.period_enddate <= cdtn.dateto AND pd.period_enddate >= cdtn.datefrom
        AND pd.period_startdate >= cdtn.datefrom AND pd.period_startdate <= cdtn.dateto		
),

tong_the_lv1 as (
select k.ad_org_id,k.hsv_toluong_id,k.hsv_nhanvien_id as a1,
	hsv_ngaycong as ngay_cong,
	hsv_luongbhxh as luong_cb,
	case when tongcong <>0 then(hsv_ngaycong* hsv_hesoluong)* (tongluong/tongcong) else 0 end as a4,
	case when k.hsv_htbhxh = 'Y' then  w.hsv_maxHTBHXH else 0 end as a5,
	hsv_ngayanca*hsv_ht_anca as anca,
	(hsv_ngaytangca2*hsv_muc_tc2+ hsv_ngaytangca3*hsv_muc_tc3+hsv_congdem* hsv_bddem) as a7,
	hsv_luongspnv as luongspnv ,
	hsv_luongbhxh*hsv_tlbhxh/100 as a10,
	w.hsv_tlkpcd as hsv_tlkpcd ,
	w.hsv_max_kpcd as hsv_max_kpcd,
	w.hsv_muc_anca * k.hsv_ngayanca +k.hsv_congdem * w.hsv_andem + k.hsv_ngaytangca2 * w.hsv_antangca2 + k.hsv_ngaytangca3*w.hsv_antangca3 as a11,
	k.hsv_ckluong as a13,hsv_hesoluong as a15,hsv_tlhtbhxh/100 as a16,
	coalesce(case when hsv_ngaycong <> 0 then t.hsv_phucap else 0 end,0) as hsv_phucap,
	hsv_phucapnv,
	t.hsv_luongcd as hsv_luongcd,
	t.hsv_maxcong as hsv_maxcong,
	t.congmax as congmax,
	hsv_hesoluong as hesoluong 
from chi_tiet_luong_bhxh k
left join chuyen_khoan as g on k.hsv_toluong_id =g.hsv_toluong_id and k.hsv_nhanvien_id =g.hsv_nhanvien_id	
left join che_do as w on  w.hsv_toluong_id = k.hsv_toluong_id  
left join tong_cong as  z on k.hsv_toluong_id = z.hsv_toluong_id	
left join tong_luong as h on k.hsv_toluong_id = h.hsv_toluong_id 
left join luong_cung as t on k.hsv_toluong_id= t.hsv_toluong_id and k.hsv_nhanvien_id =t.a1
),

tong_the_lv2 as ( 
select t.ad_org_id,
	t.hsv_toluong_id,
	a1 ,
	ngay_cong,
	hesoluong,
	luong_cb,
	coalesce(a4,0) as a4,
	case when  ngay_cong=0 then 0 else case when   (luong_cb*a16)<a5 then (luong_cb* a16) else a5 end end as a5,
	anca,
	a7,
	luongspnv+ t.hsv_phucap + case when t.hsv_maxcong<>0 and ngay_cong>= congmax then  t.hsv_luongcd/t.hsv_maxcong*a15*congmax  else case when hsv_maxcong <> 0 then  t.hsv_luongcd/t.hsv_maxcong*a15*ngay_cong else 0 end end  as  luong_pc_khac ,
	hsv_phucapnv,
	a10 , 
	coalesce(t.hsv_tlkpcd,0) hsv_tlkpcd,
	coalesce(t.hsv_max_kpcd,0) as hsv_max_kpcd,
	coalesce(a11,0) as a11,
	coalesce(a13,0) as a13,
	coalesce(a15,0) as a15
	from tong_the_lv1 as t
),
tong_the_lv3 as (
	select t.hsv_toluong_id,
	tl.name as a0,
	nv.name as hoten,
	nv.cmtnd,
	nv.iban,
	cb.name as nh,
	ngay_cong,
	hesoluong,
	luong_cb, a4,a5,anca,a7,luong_pc_khac, a4+a5+a7+luong_pc_khac as a9,hsv_phucapnv,a10,a11,
	case 
 when ngay_cong = 0 then 0
 else
   case
     when (
           (coalesce(a4,0)+coalesce(luong_pc_khac,0)+hsv_phucapnv+coalesce(a7,0))
           -(a10-a5)
           -(a11-anca)
          ) * t.hsv_tlkpcd/100 > t.hsv_Max_KPCD
     then t.hsv_Max_KPCD
     else
          (
           (coalesce(a4,0)+coalesce(luong_pc_khac,0)+hsv_phucapnv+coalesce(a7,0))
           -(a10-a5)
           -(a11-anca)
          ) * t.hsv_tlkpcd/100
   end end as tru_cd,a13,a15 ,
	case when nv.hsv_ctv = 'Y' then 0 else npt.songuoi_pt end as songuoi_pt,  
	case when (nv.hsv_ctv = 'Y') then 0 else tncn.hsv_gtgcbt end  as gtbt,
	case when (nv.hsv_ctv = 'Y' ) then 0 else tncn.hsv_GTGCNPT*coalesce(npt.songuoi_pt ,0) end as gtgcnpt,
	nv.hsv_ctv 
	from tong_the_lv2 t
	join hsv_toluong tl on t.hsv_toluong_id = tl.hsv_toluong_id
	join hsv_nhanvien nv on t.a1 = nv.hsv_nhanvien_id 
	left join c_bank cb on cb.c_bank_id = nv.c_bank_id 
	left join nguoi_pt npt on npt.hsv_nhanvien_id = nv.hsv_nhanvien_id 
	LEFT JOIN  chedo_tncn tncn ON TRUE
	where (t.ad_org_id =$P{AD_Org_ID} or $P{AD_Org_ID} is null)
), 
tong_the_lv4 as (
	select hsv_toluong_id, a0, hoten,cmtnd,iban as stk,nh,coalesce(ngay_cong,0) as ngay_cong,
	hesoluong,ngay_cong*hesoluong as hsqd, coalesce(luong_cb,0) as luong_cb,
	coalesce(a4,0)+coalesce(luong_pc_khac,0) as luongsp,
	hsv_phucapnv as pc_khac, coalesce(a7,0) as pc_andem,
	coalesce(a4,0)+coalesce(luong_pc_khac,0)+ hsv_phucapnv +coalesce(a7,0) as tong_luong,
	a5 as htbhxh,
	a10 - a5 as tru_bhxh ,
	a11  - anca as tru_tien_an,
	tru_cd,
	coalesce(a4,0)+coalesce(luong_pc_khac,0)+ hsv_phucapnv+coalesce(a7,0)  -(a11 - anca) -(a10 - a5) -tru_cd   as thuclinh,
	coalesce(songuoi_pt,0) as songuoi_pt,
	gtbt,GTGCNPT,
	case when coalesce(a4,0)+coalesce(luong_pc_khac,0)+ hsv_phucapnv+coalesce(a7,0)  -(a11 - anca) -(a10 - a5) -(coalesce(gtbt,0) +coalesce(gtgcnpt,0)) <0 then 0 else coalesce(a4,0)+coalesce(luong_pc_khac,0)+ hsv_phucapnv+coalesce(a7,0)  -(a11 - anca) -(a10 - a5) -(coalesce(gtbt,0) +coalesce(gtgcnpt,0)) end as tnct
	,hsv_ctv 
	from tong_the_lv3 
	where coalesce(a9,0)<>0
),
tong_the_lv5 as (
select hsv_toluong_id,a0,hoten,cmtnd,stk,nh,ngay_cong ,hesoluong ,luong_cb ,luongsp, pc_khac,
pc_andem,tong_luong,htbhxh,tru_bhxh ,tru_tien_an ,tru_cd ,thuclinh, songuoi_pt ,gtbt ,gtgcnpt ,tnct,
CASE WHEN hsv_ctv = 'Y' THEN 
        CASE
            WHEN tnct <= 10000000 THEN tnct * 0.05
            WHEN tnct <= 30000000 THEN tnct * 0.1  - 500000
            WHEN tnct <= 60000000 THEN tnct * 0.2  - 3500000
            WHEN tnct <= 100000000 THEN tnct * 0.3 - 9500000
            ELSE tnct * 0.35 - 14500000
        END

    -- Nhóm Nhân viên chính thức
    WHEN hsv_ctv = 'N' THEN
        CASE 
            WHEN tnct <= 10000000 THEN tnct * 0.05
            WHEN tnct <= 30000000 THEN tnct * 0.1  - 500000
            WHEN tnct <= 60000000 THEN tnct * 0.2  - 3500000
            WHEN tnct <= 100000000 THEN tnct * 0.3 - 9500000
            ELSE tnct * 0.35 - 14500000
        END    

    ELSE 0 
END AS thue_tncn
from tong_the_lv4 
),

tong_the_final_1 as (
	select  sum(tru_tien_an) as tru_tien_an,sum(tru_cd) as tru_cd ,sum(htbhxh +tru_bhxh) as bhxh ,sum(thue_tncn) as thue_tncn,sum(thuclinh-thue_tncn) as conlai 
	from tong_the_lv5  
),
tong_the_final_2 as (
	select  cb.value as doitac,cb.name as doitac_name,ac.value as hoatdong,ev.value as tk,
	sum(thuclinh-thue_tncn) as conlai,sum(luongsp+pc_khac) as luong,sum(htbhxh) as ht_bhxh,
	sum(pc_andem) as pc_andem 
	from tong_the_lv5 lv5
	join  hsv_toluong tl on tl.hsv_toluong_id = lv5.hsv_toluong_id 
	join c_bpartner cb on cb.c_bpartner_id = tl.c_bpartner_id 
	join c_activity ac on ac.c_activity_id = tl.c_activity_id
	join c_elementvalue ev on ev.c_elementvalue_id = tl.account_id
	group by cb.value ,cb.name,ac.value ,ev.value 
)

select header_org,header_sche, header_sct,header_desc,header_type,header_gl,header_date,header_period,
detail_org,detail_sct,row_number() over()  *10 as detail_stt,detail_desc,detail_doitac,detail_tk,detail_hoatdong
,detail_curencty,detail_tno,detail_tco
from (
select  case when dt.stt = 10 then   dm.org_name else null end as header_org
,case when dt.stt = 10 then  dm.sche_name else null end as header_sche
,case when dt.stt = 10 then concat('LNG.', to_char(dm.ngay,'DDMMYY')) else null end  as header_sct
,case when dt.stt = 10 then concat('Chi phí tiền lương ', dm.org_name, to_char(dm.ngay,' MM/YYYY')) else null end as header_desc
, case when dt.stt = 10 then dm.c_type else null end as header_type
, case when dt.stt = 10 then dm.gl_name else null end as header_gl
,case when dt.stt = 10 then to_char(dm.ngay,'YYYY-MM-DD') else null end  as header_date
,case when dt.stt = 10 then to_char(dm.ngay,'MM-YYYY') else null end as header_period,
dm.org_name as detail_org, concat('LNG.', to_char(dm.ngay,'DDMMYY'))  as detail_sct, stt  as detail_stt,
concat('Chi phí ',dt.cotluong,' - ',dt.doitac_name)  as detail_desc ,
doitac as detail_doitac,tk as detail_tk,
dt.hoatdong as detail_hoatdong,dt.currency as detail_curencty,0 as detail_tno,
 CASE dt.hsv_cotluong
    WHEN 'tru_bhxh' THEN round(fn.bhxh,0)
    WHEN 'tru_anca' THEN round(fn.tru_tien_an,0)
    when 'tru_congdoan' then round(fn.tru_cd,0)
    when 'TRU_TTNCN' then round(fn.thue_tncn,0)
    when 'luong_ck' then round(fn.conlai,0)
END AS detail_tco,dt.hsv_cotluong
from dm_header dm
cross join dm_chi_tiet dt
cross join tong_the_final_1 fn 
where dt.hsv_cotluong in ('tru_bhxh','tru_anca','tru_congdoan','TRU_TTNCN','luong_ck') 

union all 

select  null  as header_org
,null as header_sche
,null as header_sct
,null as header_desc
,null as header_type
,null as header_gl
,null as header_date
,null as header_period,
dm.org_name as detail_org, concat('LNG.', to_char(dm.ngay,'DDMMYY'))  as detail_sct, 
stt as detail_stt,
concat('Chi phí ',dt.cotluong,' - ',fn.doitac_name)  as detail_desc ,
fn.doitac as detail_doitac,
case  when dt.hsv_cotluong in ('luong_conlai', 'ht_bhxh' , 'ht_anca','luong_ck') then dt.tk
else fn.tk end as detail_tk,
fn.hoatdong as detail_hoatdong,dt.currency as detail_curencty,
 CASE dt.hsv_cotluong
   	when 'luong' then round(fn.luong,0)
   	when 'ht_anca' then round (fn.pc_andem,0)
   	when 'ht_bhxh' then round (fn.ht_bhxh,0)
   	when 'luong_ck' then round (fn.conlai,0) 
   	else 0
END AS detail_tno,
CASE dt.hsv_cotluong
    WHEN 'luong_conlai' THEN round(fn.conlai ,0) else 0 end  
    as detail_tco,dt.hsv_cotluong
from dm_header dm
cross join dm_chi_tiet dt
cross join tong_the_final_2 fn 
where dt.hsv_cotluong in ('luong_conlai','luong','ht_anca','ht_bhxh','luong_ck') 
) as k
where detail_tno+detail_tco <>0]]>
	</queryString>
