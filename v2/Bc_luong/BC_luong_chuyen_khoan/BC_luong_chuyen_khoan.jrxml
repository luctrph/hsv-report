<!-- Created with Jaspersoft Studio version 6.20.6.final using JasperReports Library version 6.20.6-5c96b6aa8a39ac1dc6b6bea4b81168e16dd39231  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rpt_PayMent" pageWidth="595" pageHeight="842" columnWidth="565" leftMargin="20" rightMargin="10" topMargin="8" bottomMargin="5" uuid="eeb9a7ca-fbec-4064-b5c8-8022aeead731">
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.keep.first.band.1" value="columnHeader"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.band.2" value="pageFooter"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.band.3" value="groupHeader"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.rows" value="true"/>
	<property name="net.sf.jasperreports.export.xls.remove.empty.space.between.columns" value="true"/>
	<property name="net.sf.jasperreports.export.xls.white.page.background" value="false"/>
	<property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xls.ignore.graphics" value="false"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.band.1" value="pageHeader"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.group.3" value="ProductGroup"/>
	<property name="net.sf.jasperreports.export.xls.exclude.origin.report.3" value="ProductReport"/>
	<property name="net.sf.jasperreports.export.xls.ignore.cell.border" value="false"/>
	<property name="com.jaspersoft.studio.unit.pageHeight" value="pixel1"/>
	<property name="com.jaspersoft.studio.unit.pageWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.topMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.bottomMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.leftMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.rightMargin" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnWidth" value="pixel"/>
	<property name="com.jaspersoft.studio.unit.columnSpacing" value="pixel"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="0"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="1000"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<import value="org.compiere.util.Msg"/>
	<import value="org.compiere.util.Language"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Period_ID" class="java.lang.Integer"/>
	<parameter name="C_Bank_ID" class="java.lang.Integer"/>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="CURRENT_LANG" class="java.lang.String"/>
	<parameter name="hsv_toluong_ID" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[WITH p AS (
    SELECT startdate AS period_startdate,
           enddate   AS period_enddate
    FROM c_period
    WHERE c_period_id = $P{C_Period_ID}
      AND ad_client_id = $P{AD_CLIENT_ID}
),

tong_luong AS (
    SELECT nkl.hsv_toluong_id,
           sum(nklsp.amount) AS tongluong
    FROM hsv_nkluongsp nklsp
    LEFT JOIN hsv_nkluong nkl ON nkl.hsv_nkluong_id = nklsp.hsv_nkluong_id
    WHERE nkl.c_period_id = $P{C_Period_ID}
      AND nklsp.isactive = 'Y'
      AND nkl.isactive   = 'Y'
    GROUP BY nkl.hsv_toluong_id
),

tong_cong AS (
    SELECT nkl.hsv_toluong_id,
           sum(nklnv.hsv_ngaycong * nklnv.hsv_hesoluong) AS tongcong
    FROM hsv_nkluongnv nklnv
    LEFT JOIN hsv_nkluong nkl ON nkl.hsv_nkluong_id = nklnv.hsv_nkluong_id
    WHERE nkl.c_period_id = $P{C_Period_ID}
      AND nklnv.isactive = 'Y'
      AND nkl.isactive   = 'Y'
    GROUP BY nkl.hsv_toluong_id
),

che_do AS (
    SELECT DISTINCT ON (tl.hsv_toluong_id)
        tl.hsv_toluong_id,
        coalesce(hsv_maxHTBHXH,   0) AS hsv_maxHTBHXH,
        coalesce(cdl.hsv_ht_anca, 0) AS hsv_ht_anca,
        coalesce(cdl.hsv_muc_tc2, 0) AS hsv_muc_tc2,
        coalesce(cdl.hsv_muc_tc3, 0) AS hsv_muc_tc3,
        coalesce(cdl.hsv_bddem,   0) AS hsv_bddem,
        coalesce(cdl.hsv_tlbhxh,  0) AS hsv_tlbhxh,
        coalesce(cdl.hsv_tlkpcd,  0) AS hsv_tlkpcd,
        coalesce(cdl.hsv_Max_KPCD,0) AS hsv_max_kpcd,
        coalesce(cdl.hsv_muc_anca,0) AS hsv_muc_anca,
        coalesce(cdl.hsv_andem,   0) AS hsv_andem,
        coalesce(cdl.hsv_antangca2,0) AS hsv_antangca2,
        coalesce(cdl.hsv_antangca3,0) AS hsv_antangca3,
        coalesce(cdl.hsv_tlhtbhxh, 0) AS hsv_tlhtbhxh,
        coalesce(cdl.hsv_cdkbhxh,  0) AS hsv_cdkbhxh,
        coalesce(cdl.hsv_TLKPCDM,  0) AS hsv_TLKPCDM
    FROM hsv_chedo cd
    LEFT JOIN hsv_cd_luong cdl ON cd.hsv_chedo_id = cdl.hsv_chedo_id AND cdl.isactive = 'Y'
    LEFT JOIN hsv_toluong  tl  ON tl.hsv_chedo_id = cd.hsv_chedo_id  AND tl.isactive  = 'Y'
    CROSS JOIN p pd
    WHERE pd.period_enddate   <= cdl.dateto
      AND pd.period_enddate   >= cdl.datefrom
      AND pd.period_startdate >= cdl.datefrom
      AND pd.period_startdate <= cdl.dateto
      AND cd.isactive = 'Y'
    ORDER BY tl.hsv_toluong_id, cdl.dateto DESC
),

chuyen_khoan AS (
    SELECT vck.hsv_nhanvien_id,
           vck.hsv_toluong_id,
           coalesce(vck.hsv_ckluong, 0) AS luongck
    FROM hsv_chuyenkhoan vck
    CROSS JOIN p pd
    WHERE pd.period_enddate   <= vck.dateto
      AND pd.period_enddate   >= vck.datefrom
      AND pd.period_startdate >= vck.datefrom
      AND pd.period_startdate <= vck.dateto
      AND vck.ad_client_id = $P{AD_CLIENT_ID}
      AND vck.isactive = 'Y'
),

luong_cung AS (
    SELECT lc.hsv_toluong_id,
           lc.hsv_nhanvien_id          AS a1,
           coalesce(hsv_phucap,  0)    AS hsv_phucap,
           coalesce(hsv_luongcd, 0)    AS hsv_luongcd,
           coalesce(hsv_maxcong, 0)    AS hsv_maxcong,
           coalesce(congmax,     0)    AS congmax,
           coalesce(lc.hsv_vl,  'N')  AS hsv_vl   -- ✏️ THÊM: cờ thu nhập vãng lai
    FROM hsv_luongcung lc
    CROSS JOIN p pd
    WHERE pd.period_enddate   <= lc.dateto
      AND pd.period_enddate   >= lc.datefrom
      AND pd.period_startdate >= lc.datefrom
      AND pd.period_startdate <= lc.dateto
      AND lc.ad_client_id = $P{AD_CLIENT_ID}
      AND lc.isactive = 'Y'
),

chi_tiet_luong_bhxh AS (
    SELECT b.ad_org_id,
        CASE WHEN a.hsv_luongbhxh > b.hsv_luongbhxh THEN a.hsv_luongbhxh ELSE 0   END AS hsv_luongbhxh,
        CASE WHEN a.hsv_luongbhxh > b.hsv_luongbhxh THEN a.hsv_htbhxh             END AS hsv_htbhxh,
        b.hsv_toluong_id,
        b.hsv_nhanvien_id,
        b.hsv_ngaycong,
        b.hsv_hesoluong,
        b.hsv_ngayanca,
        b.hsv_ngaytangca2,
        b.hsv_congdem,
        b.hsv_ckluong,
        b.hsv_ngaytangca3,
        b.hsv_luongspnv,
        b.hsv_phucapnv
    FROM (
        SELECT nv.hsv_nhanvien_id,
               MAX(nv.hsv_ngaycong)         AS ngaycongk,
               coalesce(bhxh.hsv_luongbhxh, 0) AS hsv_luongbhxh,
               bhxh.hsv_htbhxh                 AS hsv_htbhxh
        FROM hsv_nkluong nk
        JOIN hsv_nkluongnv    nv   ON nk.hsv_nkluong_id  = nv.hsv_nkluong_id
        JOIN hsv_luongbhxhline bhxh ON bhxh.hsv_nhanvien_id = nv.hsv_nhanvien_id AND bhxh.hsv_luongbhxh > 0
        CROSS JOIN p pd
        WHERE nk.ad_client_id = $P{AD_CLIENT_ID}
          AND nk.c_period_id  = $P{C_Period_ID}
          AND pd.period_enddate   <= bhxh.dateto
          AND pd.period_enddate   >= bhxh.datefrom
          AND pd.period_startdate >= bhxh.datefrom
          AND pd.period_startdate <= bhxh.dateto
        GROUP BY nv.hsv_nhanvien_id, bhxh.hsv_luongbhxh, bhxh.hsv_htbhxh
    ) AS a
    RIGHT JOIN (
        SELECT hsv_nkluongnv_id,
               0                                  AS hsv_luongbhxh,
               nkl.ad_org_id,
               nkl.hsv_toluong_id,
               nklnv.hsv_nhanvien_id,
               coalesce(hsv_ngaycong,         0) AS hsv_ngaycong,
               coalesce(nklnv.hsv_hesoluong,  0) AS hsv_hesoluong,
               coalesce(nklnv.hsv_ngayanca,   0) AS hsv_ngayanca,
               coalesce(nklnv.hsv_ngaytangca2,0) AS hsv_ngaytangca2,
               coalesce(nklnv.hsv_congdem,    0) AS hsv_congdem,
               coalesce(nklnv.hsv_ckluong,    0) AS hsv_ckluong,
               coalesce(nklnv.hsv_ngaytangca3,0) AS hsv_ngaytangca3,
               coalesce(nklnv.hsv_luongspnv,  0) AS hsv_luongspnv,
               coalesce(nklnv.hsv_phucap,     0) AS hsv_phucapnv
        FROM hsv_NkluongNV nklnv
        JOIN hsv_nkluong nkl ON nkl.hsv_nkluong_id = nklnv.hsv_nkluong_id
        WHERE nkl.ad_client_id = $P{AD_CLIENT_ID}
          AND nkl.c_period_id  = $P{C_Period_ID}
          AND nklnv.isactive   = 'Y'
    ) AS b ON a.hsv_nhanvien_id = b.hsv_nhanvien_id AND a.ngaycongk = b.hsv_ngaycong
),

nguoi_pt AS (
    SELECT hsv_nhanvien_id,
           count(hsv_nknguoipt_id) AS songuoi_pt
    FROM hsv_nknguoipt npt
    CROSS JOIN p pd
    WHERE ad_client_id = $P{AD_CLIENT_ID}
      AND (pd.period_enddate <= npt.dateto OR npt.dateto IS NULL)
      AND pd.period_enddate   >= npt.datefrom
      AND pd.period_startdate >= npt.datefrom
      AND (pd.period_startdate <= npt.dateto OR npt.dateto IS NULL)
      AND npt.isactive = 'Y'
    GROUP BY hsv_nhanvien_id
),

chedo_tncn AS (
    SELECT coalesce(hsv_gtgcbt,   0) AS hsv_gtgcbt,
           coalesce(hsv_GTGCNPT,  0) AS hsv_GTGCNPT
    FROM hsv_CDTTNCN cdtn
    CROSS JOIN p pd
    WHERE ad_client_id = $P{AD_CLIENT_ID}
      AND pd.period_enddate   <= cdtn.dateto
      AND pd.period_enddate   >= cdtn.datefrom
      AND pd.period_startdate >= cdtn.datefrom
      AND pd.period_startdate <= cdtn.dateto
),

tong_the_lv1 AS (
    SELECT k.ad_org_id,
           k.hsv_toluong_id,
           k.hsv_nhanvien_id                                                    AS a1,
           hsv_ngaycong                                                          AS ngay_cong,
           hsv_luongbhxh                                                         AS luong_cb,
           CASE WHEN tongcong <> 0
                THEN (hsv_ngaycong * hsv_hesoluong) * (tongluong / tongcong)
                ELSE 0 END                                                       AS a4,
           CASE WHEN k.hsv_htbhxh = 'Y' THEN w.hsv_maxHTBHXH ELSE 0 END       AS maxHTBHXH,
           hsv_ngayanca * hsv_ht_anca                                            AS anca,
           (hsv_ngaytangca2 * hsv_muc_tc2
            + hsv_ngaytangca3 * hsv_muc_tc3
            + hsv_congdem * hsv_bddem)                                           AS t_tang_ca,
           hsv_luongspnv                                                         AS luongspnv,
           hsv_luongbhxh * hsv_tlbhxh / 100                                     AS t_total_bhxh,
           				   
           w.hsv_tlkpcd                                                          AS hsv_tlkpcd,
           w.hsv_max_kpcd                                                        AS hsv_max_kpcd,
           w.hsv_muc_anca  * k.hsv_ngayanca
            + k.hsv_congdem    * w.hsv_andem
            + k.hsv_ngaytangca2 * w.hsv_antangca2
            + k.hsv_ngaytangca3 * w.hsv_antangca3                               AS a11,
           k.hsv_ckluong                                                         AS a13,
           hsv_hesoluong                                                         AS a15,
           hsv_tlhtbhxh / 100                                                   AS a16,
           coalesce(CASE WHEN hsv_ngaycong <> 0 THEN t.hsv_phucap ELSE 0 END, 0) AS hsv_phucap,
           hsv_phucapnv,
           t.hsv_luongcd                                                         AS hsv_luongcd,
           t.hsv_maxcong                                                         AS hsv_maxcong,
           t.congmax                                                             AS congmax,
           hsv_hesoluong                                                         AS hesoluong,
           w.hsv_cdkbhxh                                                        AS hsv_cdkbhxh,
           w.hsv_TLKPCDM                                                        AS hsv_TLKPCDM,
           t.hsv_vl                                                             AS hsv_vl,      -- ✏️ THÊM
           k.hsv_congdem * w.hsv_andem                                          AS anca_dem     -- ✏️ THÊM: ăn ca đêm
    FROM chi_tiet_luong_bhxh k
    LEFT JOIN chuyen_khoan AS g ON k.hsv_toluong_id = g.hsv_toluong_id AND k.hsv_nhanvien_id = g.hsv_nhanvien_id
    LEFT JOIN che_do       AS w ON w.hsv_toluong_id = k.hsv_toluong_id
    LEFT JOIN tong_cong    AS z ON k.hsv_toluong_id = z.hsv_toluong_id
    LEFT JOIN tong_luong   AS h ON k.hsv_toluong_id = h.hsv_toluong_id
    LEFT JOIN luong_cung   AS t ON k.hsv_toluong_id = t.hsv_toluong_id AND k.hsv_nhanvien_id = t.a1
),

tong_the_lv2 AS (
    SELECT t.ad_org_id,
           t.hsv_toluong_id,
           a1,
           ngay_cong,
           hesoluong,
           luong_cb,
           coalesce(a4, 0)   AS a4,
           CASE WHEN ngay_cong = 0 THEN 0
                WHEN (luong_cb * a16) < maxHTBHXH THEN (luong_cb * a16)
                ELSE maxHTBHXH END  AS maxHTBHXH,
           anca,
           t_tang_ca ,
           luongspnv
            + t.hsv_phucap
            + CASE WHEN t.hsv_maxcong <> 0 AND ngay_cong >= congmax
                   THEN t.hsv_luongcd / t.hsv_maxcong * a15 * congmax
                   WHEN hsv_maxcong <> 0
                   THEN t.hsv_luongcd / t.hsv_maxcong * a15 * ngay_cong
                   ELSE 0 END                                               AS luong_pc_khac,
           hsv_phucapnv,
           t_total_bhxh,
           t.hsv_tlkpcd                                                     AS hsv_tlkpcd,
           t.hsv_Max_KPCD                                                   AS hsv_max_kpcd,
           coalesce(a11, 0)  AS a11,
           coalesce(a13, 0)  AS a13,
           coalesce(a15, 0)  AS a15,
           t.hsv_cdkbhxh     AS hsv_cdkbhxh,
           t.hsv_TLKPCDM     AS hsv_tlkpcdm,
           t.hsv_vl          AS hsv_vl,     -- ✏️ THÊM
           coalesce(t.anca_dem, 0) AS anca_dem  -- ✏️ THÊM
    FROM tong_the_lv1 AS t
),

tong_the_lv3 AS (
    SELECT t.hsv_toluong_id,
           tl.name  AS a0,
           nv.name  AS hoten,
           nv.cmtnd,
           nv.iban,
           cb.name  AS nh,
           ngay_cong,
           hesoluong,
           luong_cb,
           a4,
           coalesce(maxHTBHXH, 0)             AS maxHTBHXH,
           coalesce(anca, 0)           AS anca,
           t_tang_ca ,
           coalesce(luong_pc_khac, 0)  AS luong_pc_khac,
           coalesce(a4, 0) + coalesce(t_tang_ca , 0) + coalesce(luong_pc_khac, 0) AS a9,
           coalesce(hsv_phucapnv, 0)   AS hsv_phucapnv,
           coalesce(t_total_bhxh, 0)            AS t_total_bhxh,
           coalesce(a11, 0)            AS a11,
           case
           	   when nv.hsv_qtluong = 'Y' then 0
               WHEN ngay_cong = 0 THEN 0
               WHEN coalesce(t.hsv_max_kpcd, 0) <> 0 THEN
                   LEAST(
                       (   (coalesce(a4,0) + coalesce(luong_pc_khac,0) + coalesce(hsv_phucapnv,0) + coalesce(t_tang_ca,0))
                         - (coalesce(t_total_bhxh,0) - coalesce(maxHTBHXH,0))
                         - (coalesce(a11,0) - coalesce(anca,0))
                       ) * coalesce(t.hsv_tlkpcd, 0) / 100,
                       t.hsv_max_kpcd
                   )
               ELSE
              		case
	                   when coalesce(t.hsv_TLKPCDM, 0) = 0  then 0
                       WHEN luong_cb > 0 THEN luong_cb * coalesce(t.hsv_tlkpcdm, 0) / 100
                       ELSE coalesce(t.hsv_cdkbhxh, 0)
                   END
                      
                  
           END AS tru_cd,
           a13,
           a15,
           CASE WHEN nv.hsv_ctv = 'Y' THEN 0 ELSE npt.songuoi_pt END                              AS songuoi_pt,
           CASE WHEN nv.hsv_ctv = 'Y' THEN 0 ELSE tncn.hsv_gtgcbt END                             AS gtbt,
           CASE WHEN nv.hsv_ctv = 'Y' THEN 0 ELSE tncn.hsv_GTGCNPT * coalesce(npt.songuoi_pt, 0) END AS gtgcnpt,
           nv.hsv_ctv,
           t.hsv_vl                                                                                 AS hsv_vl,   -- ✏️ THÊM
           coalesce(t.anca_dem, 0)                                                                  AS anca_dem,  -- ✏️ THÊM
           nv.hsv_qtluong
    FROM tong_the_lv2 t
    JOIN hsv_toluong   tl  ON t.hsv_toluong_id    = tl.hsv_toluong_id
    JOIN hsv_nhanvien  nv  ON t.a1                = nv.hsv_nhanvien_id
    LEFT JOIN c_bank   cb  ON cb.c_bank_id        = nv.c_bank_id
    LEFT JOIN nguoi_pt npt ON npt.hsv_nhanvien_id = nv.hsv_nhanvien_id
    LEFT JOIN chedo_tncn tncn ON TRUE
    WHERE (nv.c_bank_id  = $P{C_Bank_ID} OR $P{C_Bank_ID} IS NULL)
      AND ($P{hsv_toluong_ID} IS NULL OR t.hsv_toluong_id = ANY(string_to_array($P{hsv_toluong_ID}, ',')::integer[]))
      AND (t.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
),

tong_the_lv4 AS (
    SELECT a0, hoten, cmtnd, iban AS stk, nh,
           coalesce(ngay_cong, 0)                                   AS ngay_cong,
           hesoluong,
           ngay_cong * hesoluong                                    AS hsqd,
           case when hsv_qtluong  = 'Y' then 0 else coalesce(luong_cb, 0) end  AS luong_cb,
           coalesce(a4, 0) + coalesce(luong_pc_khac, 0)            AS luongsp,
           hsv_phucapnv                                             AS pc_khac,
           coalesce(t_tang_ca , 0)                                          AS pc_andem,
           coalesce(a4,0) + coalesce(luong_pc_khac,0) + hsv_phucapnv + coalesce(t_tang_ca ,0) AS tong_luong,
           case when hsv_qtluong = 'Y' then 0 else maxHTBHXH end                                                       AS htbhxh,
           case when hsv_qtluong = 'Y' then 0 else  t_total_bhxh - maxHTBHXH   end    AS tru_bhxh,
           a11 - anca                                               AS tru_tien_an,
           case when hsv_qtluong = 'Y' then 0 else tru_cd end as tru_cd,

           -- ✏️ THÊM: khoản trừ 10% thu nhập vãng lai = (tổng lương - anca_dem) × 10%
           CASE
               WHEN hsv_vl = 'Y'
            
               THEN ROUND(
                       (  coalesce(a4,0)
                        + coalesce(luong_pc_khac,0)
                        + coalesce(hsv_phucapnv,0)
                        + coalesce(t_tang_ca ,0)
                        - coalesce(anca_dem,0)  -  coalesce(t_tang_ca ,0)       -- trừ tiền ăn ca đêm
                       ) * 0.10, 0)
               ELSE 0
           END AS tru_vl,

           -- ✏️ SỬA: thuclinh trừ thêm tru_vl khi là vãng lai
               coalesce(a4,0) + coalesce(luong_pc_khac,0) + hsv_phucapnv + coalesce(t_tang_ca ,0)
           - (coalesce(a11,0) - coalesce(anca,0)) --tien an
           - case when hsv_qtluong = 'Y' then 0 else  (coalesce(t_total_bhxh,0) - coalesce(maxHTBHXH,0)) end  --bhxh
           - coalesce(tru_cd,0)
                
              AS thuclinh,

           coalesce(songuoi_pt, 0)                                  AS songuoi_pt,
           gtbt,
           gtgcnpt,

           -- ✏️ SỬA: tnct = 0 nếu là thu nhập vãng lai (đã trừ 10% ở tru_vl, không tính biểu lũy tiến)
           case
           	   when hsv_qtluong = 'Y' then 0
               WHEN hsv_vl = 'Y' THEN  (  coalesce(a4,0)
                        + coalesce(luong_pc_khac,0)
                        + coalesce(hsv_phucapnv,0)
                        + coalesce(t_tang_ca ,0)
                        - coalesce(anca_dem,0)-  coalesce(t_tang_ca , 0)         
                       )
               WHEN   (coalesce(a4,0) + coalesce(luong_pc_khac,0) + hsv_phucapnv + coalesce(t_tang_ca ,0))
                    - t_tang_ca 
                    - (t_total_bhxh - maxHTBHXH) -- bhxh
                    - (coalesce(gtbt,0) --tnbt 
                    	+ coalesce(gtgcnpt,0) --gtgcnpt
                    	) < 0 THEN 0
               ELSE   (coalesce(a4,0) + coalesce(luong_pc_khac,0) + hsv_phucapnv + coalesce(t_tang_ca ,0))
                     - t_tang_ca 
                    - (t_total_bhxh - maxHTBHXH) -- bhxh
                    - (coalesce(gtbt,0) + coalesce(gtgcnpt,0))
           END AS tnct,
           hsv_ctv,
           hsv_vl,   -- ✏️ THÊM: giữ để dùng trong tax_cte
           a9,
           hsv_qtluong
    FROM tong_the_lv3
    WHERE coalesce(a9, 0) <> 0
)

select row_number() over(order by nh ) as stt,hoten,stk,nh,thuclinh,thue_tncn 
from (
select a0,hoten,stk,nh,thuclinh,
	coalesce(ROUND(thuclinh-
    CASE
               
           	   when hsv_qtluong = 'Y'   then 0
               WHEN hsv_vl = 'Y'        THEN tru_vl               
               WHEN tnct <= 10000000    THEN tnct * 0.05
               WHEN tnct <= 30000000    THEN tnct * 0.10  - 500000
               WHEN tnct <= 60000000    THEN tnct * 0.20  - 3500000
               WHEN tnct <= 100000000   THEN tnct * 0.30  - 9500000
               ELSE                          tnct * 0.35  - 14500000            
    end,0),0) AS thue_tncn
from tong_the_lv4
where  hsv_qtluong = 'N'
) as k;]]>
	</queryString>
