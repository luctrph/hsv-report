	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="P_NV_ID" class="java.lang.Integer" isForPrompting="false"/>
	<parameter name="dia_chi" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT row_number( ) over() AS stt,
	npt.name AS npt_name,
	npt.birthday AS npt_ngaysinh,
	npt.taxid_npt AS npt_tax,
	CASE npt.quanhe
	    WHEN 'con'      THEN 'Con'
	    WHEN 'chame'    THEN 'Cha/Mẹ'
	    WHEN 'vochong'  THEN 'Vợ/Chồng'
	    WHEN 'khac'     THEN 'Khác'
	    ELSE npt.quanhe  
	END AS npt_quanhe, 
	case npt.quanhe 
       when 'con' then $P{dia_chi}
		end npt_diachi
FROM hsv_nknguoipt npt
WHERE 
	 npt.hsv_nhanvien_id = $P{P_NV_ID} 
	 AND npt.ad_client_id = $P{AD_CLIENT_ID} 
	 AND npt.isactive = 'Y' 
ORDER BY npt.name ]]>
	</queryString>
