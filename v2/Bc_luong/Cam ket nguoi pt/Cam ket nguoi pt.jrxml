	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
    nv.hsv_nhanvien_id,
    nv.name        AS nv_name,
    nv.taxid       AS nv_taxid,
    nv.cmtnd       AS nv_cmtnd,
    nv.date1       AS nv_date1,
    nv.diachiid    AS nv_diachi
FROM hsv_nhanvien nv
WHERE nv.ad_client_id = $P{AD_CLIENT_ID}
  AND EXISTS (
      SELECT 1 FROM hsv_nknguoipt npt
      WHERE npt.hsv_nhanvien_id = nv.hsv_nhanvien_id
        AND npt.isactive = 'Y'
  )
ORDER BY nv.name]]>
	</queryString>
