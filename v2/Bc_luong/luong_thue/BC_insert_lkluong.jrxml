	<queryString>
		<![CDATA[SELECT *
FROM (
    SELECT *
    FROM adempiere.fn_delete_lknkluong(
        $P{AD_CLIENT_ID},
        $P{AD_Org_ID},
        $P{C_Period_ID},
        $P{AD_User_ID},
        $P{delete_header}
    )
    WHERE TRIM($P{Action}) = 'delete'
	union all 
    SELECT *
    FROM adempiere.fn_insert_lknkluong(
        $P{AD_CLIENT_ID},
        $P{AD_Org_ID},
        $P{C_Period_ID},
        $P{AD_User_ID}
    )
    WHERE TRIM($P{Action}) = 'insert'
) t]]>
	</queryString>
