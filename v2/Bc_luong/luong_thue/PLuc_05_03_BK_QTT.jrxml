	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="Nam" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT 
	    row_number() over(order by nv.name) AS stt,
	    nv.name        AS nv_name,
	    nv.cmtnd,
	    npt.name       AS npt_name,
	    npt.birthday   AS npt_birth,
	    npt.TaxID_NPT,
	    case npt.quanhe 
	    	when 'con' then 'Con' 
	    	when 'chame' then 'Cha/mẹ'
	    	when 'vochong' then 'Vợ/chồng'
	    	when 'khac' then 'Khác'
	    	else npt.quanhe end as quanhe,
	    npt.datefrom
	FROM hsv_nhanvien nv
	JOIN hsv_nknguoipt npt ON npt.hsv_nhanvien_id = nv.hsv_nhanvien_id
	WHERE nv.ad_client_id = $P{AD_CLIENT_ID}
	  AND EXISTS (
	      SELECT 1 FROM hsv_lknkluong lk
	      JOIN hsv_lknkluongline lkl ON lk.hsv_lknkluong_id = lkl.hsv_lknkluong_id
	      JOIN c_period cp ON cp.c_period_id = lk.c_period_id
	      WHERE lkl.hsv_nhanvien_id = nv.hsv_nhanvien_id
	        AND EXTRACT(YEAR FROM cp.startdate) = $P{Nam}::integer
	  )]]>
	</queryString>
