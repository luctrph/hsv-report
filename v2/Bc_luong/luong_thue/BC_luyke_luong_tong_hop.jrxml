	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="HSV_ToLuong_ID" class="java.lang.Integer"/>
	<parameter name="StartDate" class="java.util.Date"/>
	<parameter name="EndDate" class="java.util.Date"/>
	<queryString>
		<![CDATA[SELECT 
    row_number() OVER(ORDER BY lkl.hsv_toluong_id,nv.name) AS stt,
    lkl.hsv_nhanvien_id,
    nv.name,
    sum(lkl.hsv_luongbhxh)                                                                 AS hsv_luongbhxh,
    sum(COALESCE(lkl.hsv_luongsp,0) + COALESCE(lkl.hsv_luongspnv,0))                      AS hsv_luongspnv,
    sum(lkl.hsv_phucap)                                                                     AS hsv_phucap,
    sum(lkl.hsv_THTTANGCA)                                                                  AS hsv_THTTANGCA,
    -- ✅ Sửa: thêm hsv_luongsp vào tongluong
    sum(COALESCE(lkl.hsv_luongsp,0) + COALESCE(lkl.hsv_luongspnv,0)
        + COALESCE(lkl.hsv_phucap,0) + COALESCE(lkl.hsv_THTTANGCA,0))                     AS tongluong,
    sum(lkl.hsv_thtbhxh)                                                                    AS hsv_thtbhxh,
    sum(COALESCE(lkl.hsv_trubhxh,0) - COALESCE(lkl.hsv_THTBHXH,0))                       AS tru_bhxh,
    sum(COALESCE(lkl.hsv_truanca,0) - COALESCE(lkl.hsv_thtanca,0))                        AS tru_tien_an,
    sum(lkl.hsv_trucongdoan)                                                                AS hsv_trucongdoan,
    -- ✅ Sửa: thêm lkl. và đổi + thành - cho thuế TNCN
    sum(COALESCE(lkl.hsv_luongconlai,0) - COALESCE(lkl.hsv_ttncn,0))                      AS thuclinh,
    sum(lkl.hsv_tnct)                                                                       AS hsv_tnct,
    sum(lkl.hsv_ttncn)                                                                      AS hsv_ttncn,
    sum(lkl.hsv_luongconlai)                                                                AS hsv_luongconlai
FROM hsv_lknkluong lk
JOIN hsv_lknkluongline lkl ON lk.hsv_lknkluong_id = lkl.hsv_lknkluong_id
JOIN hsv_nhanvien nv       ON nv.hsv_nhanvien_id   = lkl.hsv_nhanvien_id
JOIN c_period cp           ON cp.c_period_id       = lk.c_period_id
WHERE lk.ad_client_id = $P{AD_CLIENT_ID}
  AND (lkl.hsv_toluong_id = $P{HSV_ToLuong_ID} OR $P{HSV_ToLuong_ID} IS NULL)
  AND cp.startdate >= (
        SELECT MIN(cp2.startdate) FROM c_period cp2
        WHERE cp2.startdate <= $P{StartDate} AND cp2.enddate >= $P{StartDate}
  )
  AND cp.enddate <= (
        SELECT MAX(cp3.enddate) FROM c_period cp3
        WHERE cp3.startdate <= $P{EndDate} AND cp3.enddate >= $P{EndDate}
  )
GROUP BY lkl.hsv_toluong_id,nv.name, lkl.hsv_nhanvien_id]]>
	</queryString>
