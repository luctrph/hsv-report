	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="psql"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="StartDate" class="java.util.Date"/>
	<parameter name="EndDate" class="java.util.Date"/>
	<parameter name="HSV_ToLuong_ID" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT 
    row_number() OVER (ORDER BY lkl.hsv_toluong_id,nv.name) AS stt,
    nv.name,
    nv.CMTND,
    SUM(lkl.hsv_tongluong + (lkl.hsv_THTANCA - lkl.hsv_truanca))     AS tn_chiuthue,
    lkl.songuoi_pt                                                      AS so_nguoi_pt_gtgc,
    SUM(COALESCE(lkl.hsv_GTGCNPT, 0) + COALESCE(lkl.hsv_GTGCBT, 0))  AS tong_tien_gtgc,
    SUM(COALESCE(lkl.hsv_trubhxh, 0) - COALESCE(lkl.hsv_THTBHXH, 0)) AS tru_bhxh,
    SUM(lkl.HSV_TTNCN)                                                  AS thue
FROM hsv_lknkluong lk
JOIN hsv_lknkluongline lkl ON lk.hsv_lknkluong_id = lkl.hsv_lknkluong_id
JOIN hsv_nhanvien nv       ON nv.hsv_nhanvien_id   = lkl.hsv_nhanvien_id
JOIN c_period cp           ON cp.c_period_id = lk.c_period_id
WHERE lk.ad_client_id = $P{AD_CLIENT_ID} and (lkl.hsv_toluong_id = $P{HSV_ToLuong_ID} or $P{HSV_ToLuong_ID} is null)
  AND cp.startdate >= (
        SELECT MIN(cp2.startdate)
        FROM c_period cp2
        WHERE cp2.startdate <= $P{StartDate}      -- kỳ chứa ngày bắt đầu
          AND cp2.enddate   >= $P{StartDate}
  )
  AND cp.enddate <= (
        SELECT MAX(cp3.enddate)
        FROM c_period cp3
        WHERE cp3.startdate <= $P{EndDate}        -- kỳ chứa ngày kết thúc
          AND cp3.enddate   >= $P{EndDate}
  )
GROUP BY nv.name, nv.CMTND, lkl.songuoi_pt,lkl.hsv_toluong_id]]>
	</queryString>
	<field name="stt" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="stt"/>
		<property name="com.jaspersoft.studio.field.label" value="stt"/>
	</field>
	<field name="name" class="java.lang.String">
