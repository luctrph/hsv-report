		<property name="com.jaspersoft.studio.field.tree.path" value="hsv_nhanvien"/>
	</field>
	<field name="tn_chiuthue" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="tn_chiuthue"/>
		<property name="com.jaspersoft.studio.field.label" value="tn_chiuthue"/>
	</field>
	<field name="so_nguoi_pt_gtgc" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="so_nguoi_pt_gtgc"/>
		<property name="com.jaspersoft.studio.field.label" value="so_nguoi_pt_gtgc"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="hsv_lknkluongline"/>
	</field>
	<field name="tong_tien_gtgc" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="tong_tien_gtgc"/>
		<property name="com.jaspersoft.studio.field.label" value="tong_tien_gtgc"/>
	</field>
	<field name="tru_bhxh" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="tru_bhxh"/>
		<property name="com.jaspersoft.studio.field.label" value="tru_bhxh"/>
	</field>
	<field name="thue" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="thue"/>
		<property name="com.jaspersoft.studio.field.label" value="thue"/>
	</field>
	<variable name="tntt" class="java.lang.Double">
		<variableExpression><![CDATA[$F{tn_chiuthue}.doubleValue()-$F{tong_tien_gtgc}.doubleValue() - $F{tru_bhxh}.doubleValue()]]></variableExpression>
	</variable>
	<variable name="sum_tn_chiuthue" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{tn_chiuthue}]]></variableExpression>
	</variable>
	<variable name="sum_snpt" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{so_nguoi_pt_gtgc}]]></variableExpression>
	</variable>
	<variable name="sum_tong_tien_gtgc" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{tong_tien_gtgc}]]></variableExpression>
	</variable>
	<variable name="sum_tru_bhxh" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{tru_bhxh}]]></variableExpression>
	</variable>
	<variable name="sum_thue" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{thue}]]></variableExpression>
	</variable>
	<variable name="sum_thunhaptinhthue" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$V{tntt} <0?0:$V{tntt}]]></variableExpression>
	</variable>
