<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Luy_ke_luong" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="2be2e95e-935e-4f64-9865-c205bb9b4657">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="hsv_nhanvien_ID" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[
    SELECT 
    cp.name as thang,    
    nv.name,    
    tl.name AS to_luong,
    lkl.hsv_luongconlai,
    hsv_trubhxh - lkl.hsv_thtbhxh AS trubhxh,
    hsv_ttncn,
    SUM(lkl.hsv_luongconlai) OVER (PARTITION BY lkl.hsv_nhanvien_id ORDER BY cp.name, lk.hsv_lknkluong_id) AS luy_ke,
    SUM(hsv_trubhxh - lkl.hsv_thtbhxh) OVER (PARTITION BY lkl.hsv_nhanvien_id ORDER BY cp.name, lk.hsv_lknkluong_id) AS luy_ke_trubhxh,
    SUM(hsv_ttncn) OVER (PARTITION BY lkl.hsv_nhanvien_id ORDER BY cp.name, lk.hsv_lknkluong_id) AS luy_ke_ttncn
FROM 
    hsv_lknkluong lk
JOIN 
    hsv_lknkluongline lkl ON lk.hsv_lknkluong_id = lkl.hsv_lknkluong_id
JOIN 
    hsv_nhanvien nv ON nv.hsv_nhanvien_id = lkl.hsv_nhanvien_id 
JOIN 
    hsv_toluong tl ON tl.hsv_toluong_id = lkl.hsv_toluong_id 
JOIN 
    c_period cp ON cp.c_period_id = lk.c_period_id
WHERE 
    lk.ad_client_id = $P{AD_CLIENT_ID}
    AND lkl.hsv_nhanvien_id = $P{hsv_nhanvien_ID}

]]>
	</queryString>
