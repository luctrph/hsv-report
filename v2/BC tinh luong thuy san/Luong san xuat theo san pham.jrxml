	           SUM(productionqty) FILTER (
	               WHERE C_Campaign_ID = 1000107
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000869,1000870,1000871,1000872)
	           )
	    FROM nhap_kho_tt
	    union all 
	    select 'V.09' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000615)
