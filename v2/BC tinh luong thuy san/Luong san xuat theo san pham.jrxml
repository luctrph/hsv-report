	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	              	 AND M_AttributeSet_ID = 1000199
	                 AND value1 = 1000904
	   				AND value2 in (1000848,1000164,1000008,1000847,1000233,1000161,1000005,1000176,1000160,1000200)
	     			AND M_Attribute_ID = 1000150
	           )
	    FROM nhap_kho_tt_tt
	    union all 
	    select 'V.17' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000625)
