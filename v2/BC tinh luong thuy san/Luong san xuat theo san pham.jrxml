	                 AND value1 in (1000880,1000891) AND att1 = 1000146 
	                 AND value2 <> 1000916 AND att2 = 1000153 
	           )  
	    FROM nhap_kho_tt_tt_tt 
	    union all 
	    select 'VI' as id, null as qty
	    union all 
	    SELECT 'VI.01',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000882,1000886,1000889)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.02',
