	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000892,1000893)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.03',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000877,1000890)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.04',
