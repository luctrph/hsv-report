	                 AND m_attributeset_id in (1000200,1000201)
	                 AND M_AttributeValue_ID = 1000925
	           )
	    FROM nhap_kho_tt
	    union all 
	    select 'XI.05', 
		           SUM(productionqty) FILTER (
