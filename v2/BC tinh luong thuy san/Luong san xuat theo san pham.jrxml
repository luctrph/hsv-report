		                 AND m_attributeset_id in (1000200,1000201)
		                 AND m_attributevalue_id in (1000926,1000925,1000923,1000927,1000928,1000924)
		           )
		FROM nhap_kho_tt
		union all 
		select 'XI.06', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104,1000107)
	                 AND m_attributeset_id = 1000200
	                 AND m_attributevalue_id in (1000894,1000897)
	           )
	    FROM nhap_kho_tt
	    union all 
		select 'XI.07', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104,1000107)
	                 AND m_attributeset_id = 1000200
	                 AND M_AttributeValue_ID = 1000896
	           )
	    FROM nhap_kho_tt
	    union all 
		select 'XI.08', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104,1000107)
	                 AND m_attributeset_id = 1000200
	                 AND m_attributevalue_id = 1000898
	           )
	    FROM nhap_kho_tt
	    union all 
	    select 'XI.09', null
		union all 
		select 'XI.10', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104,1000107)
	                 AND m_attributeset_id = 1000200
	                 AND M_AttributeValue_ID = 1000895
	           )
	    FROM nhap_kho_tt
		union all 
		select 'XII', null
		union all
		select 'XII.01',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019527,1019528,1019529,1019530,1019524,1019525)
			 AND c_campaign_id in (1000105,1000104)
			)
		FROM nhap_kho
		union all
		select 'XII.02',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019527,1019528,1019529,1019530,1019524,1019525)
			 AND c_campaign_id in (1000105,1000104,1000107)
			)
		FROM nhap_kho
		union all
		select 'XII.03',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019878,1019533,1019532)
			 AND c_campaign_id in (1000105,1000104)
			)
		FROM nhap_kho
		union all
		select 'XII.04',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019526)
			 AND c_campaign_id in (1000105,1000104)
			)
		FROM nhap_kho
		union all
		select 'XII.05',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019526)
			 AND c_campaign_id in (1000105,1000104)
			)
		FROM nhap_kho
		union all
		select 'XII.06', sum(qty) as qty
		FROM (
			select 0 as qty 
			union all
			select -1*0.2*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019528,1019529) 
				 	AND c_campaign_id in (1000105,1000104)
			)			
			FROM nhap_kho
			union all 
			select -1*0.1*sum(productionqty) FILTER (
				 WHERE M_Product_ID = 1019530
				 	AND c_campaign_id in (1000105,1000104)
			)
			FROM nhap_kho
			union all 
			select -1*0.1*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019524,1019525) AND M_AttributeValue_ID = 1000913
				 	AND c_campaign_id in (1000105,1000104)
			)
			FROM nhap_kho_tt
			union all 
			select -1*0.2*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019524,1019525) AND M_AttributeValue_ID = 1000914
				 	AND c_campaign_id in (1000105,1000104)
			)
			FROM nhap_kho_tt
			union all 
			select -1*0.25*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019524,1019525) AND M_AttributeValue_ID = 1000915
				 	AND c_campaign_id in (1000105,1000104)
			)
			FROM nhap_kho_tt
		) as k 
		union all
		select 'XII.07', sum(qty) as qty
		FROM (
			select 0 as qty 
			union all
			select -1*0.2*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019528,1019529) 
				 	AND c_campaign_id in (1000105,1000104,1000107)
			)			
			FROM nhap_kho
			union all 
			select -1*0.1*sum(productionqty) FILTER (
				 WHERE M_Product_ID = 1019530
				 	AND c_campaign_id in (1000105,1000104,1000107)
			)
			FROM nhap_kho
			union all 
			select -1*0.1*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019524,1019525) AND M_AttributeValue_ID = 1000913
				 	AND c_campaign_id in (1000105,1000104,1000107)
			)
			FROM nhap_kho_tt
			union all 
			select -1*0.2*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019524,1019525) AND M_AttributeValue_ID = 1000914
				 	AND c_campaign_id in (1000105,1000104,1000107)
			)
			FROM nhap_kho_tt
			union all 
			select -1*0.25*sum(productionqty) FILTER (
				 WHERE m_product_id in (1019524,1019525) AND M_AttributeValue_ID = 1000915
				 	AND c_campaign_id in (1000105,1000104,1000107)
			)
			FROM nhap_kho_tt
		) as k 
		union all 
		select 'XII.08', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104,1000107)
	                 AND M_AttributeSet_ID = 1000202
	                 AND m_attributevalue_id in (1000894,1000897)
	           )
	    FROM nhap_kho_tt
	    union all 
		select 'XII.09', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104,1000107)
	                 AND M_AttributeSet_ID = 1000202
	                 AND M_AttributeValue_ID = 1000896
	           )
	    FROM nhap_kho_tt
	    union all 
		select 'XII.10', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104,1000107)
	                 AND M_AttributeSet_ID = 1000202
	                 AND M_AttributeValue_ID = 1000895
	           )
	    FROM nhap_kho_tt
		union all
		select 'XIII', null
		union all 
		select 'XIII.01',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019532,1019878)
			 AND c_campaign_id in (1000105,1000104)
			)
		FROM nhap_kho
		union all 
		select 'XIII.02',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019879,1019534)
			 AND c_campaign_id in (1000105,1000104)
			)
		FROM nhap_kho
		union all 
		select 'XIII.03',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019532,1019533,1019534)
			 AND c_campaign_id in (1000105,1000104,1000107) AND M_AttributeValue_ID = 1000899
			)
		FROM nhap_kho_tt 
		union all 
		select 'XIII.04',
			sum(productionqty) FILTER (
			 WHERE m_product_id in (1019532,1019533,1019534) 
			 AND c_campaign_id in (1000105,1000104,1000107) AND M_AttributeValue_ID = 1000900
			)
		FROM nhap_kho_tt 
		union all 
		select 'XIV', null
		union all 
		select 'XIV.01' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000621)
	    FROM nhatky_sx 
	) t
	GROUP BY id
) 

SELECT
    dm.hsv_stt,
    split_part(dm.value, '.', 1) AS group_value,
    dm.value,
    dm.name,
    fil.qty,
    dg.hsv_dongialuong,
    CASE
        WHEN dm.value IN ('II.01','II.02','II.06','II.07','II.08','II.11','II.12')
            THEN fil.qty * dg.hsv_dongialuong / 1.15
        ELSE fil.qty * dg.hsv_dongialuong
    END AS tt
FROM filter_data fil 
JOIN danhmuc dm ON fil.id = dm.value
LEFT JOIN dongia dg ON dg.hsv_luongsxvh_id = dm.hsv_luongsxvh_id
ORDER BY dm.value, dm.hsv_stt::numeric::int ASC]]>
	</queryString>
