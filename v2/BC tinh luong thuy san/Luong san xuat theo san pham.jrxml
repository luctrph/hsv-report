	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="StartDate" class="java.util.Date"/>
	<parameter name="EndDate" class="java.util.Date"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[with dongia AS (
    SELECT DISTINCT ON (dgl.hsv_luongsxvh_id)
           dgl.hsv_luongsxvh_id,
           dgl.hsv_dongialuong,
           dg.startdate,
           dg.enddate  
    FROM hsv_dgluong dg 
    JOIN hsv_dgluongLine dgl ON dg.hsv_dgluong_id = dgl.hsv_dgluong_id 
    WHERE dg.hsv_loaidongia_id = 1000079 
      AND dg.ad_client_id = $P{AD_CLIENT_ID}
      AND dg.startdate <= $P{EndDate}
      AND (dg.enddate IS NULL OR dg.enddate >= $P{StartDate})
    ORDER BY dgl.hsv_luongsxvh_id, dg.startdate DESC
),

danhmuc AS (
    SELECT lsx.hsv_luongsxvh_id, 
           trim(lsx.value) AS value, 
           name,
           hsv_stt 
    FROM hsv_luongsxvh lsx 
    WHERE lsx.ad_client_id = $P{AD_CLIENT_ID} 
      AND lsx.isactive = 'Y'
),

nhatky_sx as (
	select nkl.hsv_sanpham_id, nkl.qtyother  
	from hsv_nhatkysx nk
	join hsv_nhatkysxline nkl on nk.hsv_nhatkysx_id = nkl.hsv_nhatkysx_id 
	where nk.ad_client_id = $P{AD_CLIENT_ID} 
	  and nk.dateacct >= $P{StartDate} 
	  and nk.dateacct <= $P{EndDate}
),

chuyen_kho as (
	select civ.m_product_id,
		civ.m_locator_id,
		civ.movementqty 		
	from m_movement ci
	join m_movementline civ on ci.m_movement_id = civ.m_movement_id 
	WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO')
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}	     
),

xuat_ban as (
	select hh.m_attributeset_id,
	civ.qtyentered, civ.m_locator_id
	from m_inout ci 
	join m_inoutline civ on ci.m_inout_id = civ.m_inout_id 
	join m_product hh on hh.m_product_id = civ.m_product_id 
	WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO') and ci.issotrx='Y'
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}	
),

xuat_ban_tt as (
	select hh.m_attributeset_id, ma.m_attributevalue_id, 
	civ.qtyentered, civ.m_locator_id
	from m_inout ci 
	join m_inoutline civ on ci.m_inout_id = civ.m_inout_id 
	join m_attributeinstance ma on ma.m_attributesetinstance_id = civ.m_attributesetinstance_id  
	join m_product hh on hh.m_product_id = civ.m_product_id 
	WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO') and ci.issotrx='Y'
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}	
),

nhap_mua as (
	select civ.qtyentered, civ.m_product_id 
	from m_inout ci 
	join m_inoutline civ on ci.m_inout_id = civ.m_inout_id 
	WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO') and ci.issotrx='N'
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}	
),

xuat_kho as (
	select hh.m_attributeset_id, 
	civ.m_locator_id,
	civ.QtyInternalUse
	from m_inventory ci 
	join m_inventoryline civ on ci.m_inventory_id = civ.m_inventory_id 
	join m_product hh on hh.m_product_id = civ.m_product_id 
	WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO')
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}	
),

nhap_kho as (
	SELECT ci.c_campaign_id,
           ci.movementdate,
           civ.productionqty,
           hh.m_attributeset_id,      
           civ.m_locator_id,
           civ.m_product_id 
    FROM m_production ci
    JOIN m_productionplan civ ON ci.m_production_id = civ.m_production_id
    JOIN m_product hh ON hh.m_product_id = civ.m_product_id
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO')
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
),

nhap_kho_tt AS (
    SELECT ci.c_campaign_id,
           ci.movementdate,
           civ.productionqty,
           hh.m_attributeset_id,
           ma.m_attributevalue_id,
           civ.m_locator_id,
           civ.m_product_id,
           ma.m_attribute_id 
    FROM m_production ci
    JOIN m_productionplan civ ON ci.m_production_id = civ.m_production_id
    JOIN m_product hh ON hh.m_product_id = civ.m_product_id
    LEFT JOIN m_attributeinstance ma 
           ON ma.m_attributesetinstance_id = civ.m_attributesetinstance_id
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO')
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
),

nhap_kho_tt_tt AS (
    SELECT ci.c_campaign_id,
           ci.movementdate,
           civ.productionqty,
           hh.m_attributeset_id,
           ma.m_attributevalue_id as value1,
           ma1.m_attributevalue_id as value2, 
           ma.m_attribute_id, 
           civ.m_locator_id,
           civ.m_product_id 
    FROM m_production ci
    JOIN m_productionplan civ ON ci.m_production_id = civ.m_production_id
    JOIN m_product hh ON hh.m_product_id = civ.m_product_id
    LEFT JOIN m_attributeinstance ma 
           ON ma.m_attributesetinstance_id = civ.m_attributesetinstance_id
    LEFT JOIN m_attributeinstance ma1 
           ON ma1.m_attributesetinstance_id = civ.m_attributesetinstance_id
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO')
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
),

nhap_kho_tt_tt_tt AS (
    SELECT ci.c_campaign_id,
           ci.movementdate,
           civ.productionqty,
           hh.m_attributeset_id,
           ma.m_attributevalue_id as value1,
           ma1.m_attributevalue_id as value2, 
           ma.m_attribute_id as att1, 
           ma1.m_attribute_id as att2, 
           civ.m_locator_id,
           civ.m_product_id 
    FROM m_production ci
    JOIN m_productionplan civ ON ci.m_production_id = civ.m_production_id
    JOIN m_product hh ON hh.m_product_id = civ.m_product_id
    LEFT JOIN m_attributeinstance ma 
           ON ma.m_attributesetinstance_id = civ.m_attributesetinstance_id
    LEFT JOIN m_attributeinstance ma1 
           ON ma1.m_attributesetinstance_id = civ.m_attributesetinstance_id
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.docstatus IN ('CL','CO')
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
),

-- ============================================================
-- CÁC CTE TỪ QUERY 2 — dùng để tính II.09 = kq7.ngao_nau
-- ============================================================

-- Giao dịch ngao nâu (có thuộc tính)
giao_dich_ngao AS (
    SELECT
        ma.m_attribute_id,
        mav.hsv_c_thuoctinh_id,
        m.movementdate,
        m.movementqty,
        RIGHT(m.movementtype, 1) AS tang_giam
    FROM m_transaction m
    JOIN m_product hh ON hh.m_product_id = m.m_product_id
    JOIN m_attributeinstance ma ON ma.m_attributesetinstance_id = m.m_attributesetinstance_id  
    JOIN m_attributevalue mav ON mav.m_attributevalue_id = ma.m_attributevalue_id 
    WHERE m.ad_client_id = $P{AD_CLIENT_ID}
      AND m.movementdate <= $P{EndDate} 
      AND hh.m_product_id = 1019435
),

-- Giao dịch tổng (ngao trắng + ngao nâu)
giao_dich_ngao_tong AS (
    SELECT
        m.movementdate,
        m.movementqty,
        RIGHT(m.movementtype, 1) AS tang_giam
    FROM m_transaction m
    JOIN m_product hh ON hh.m_product_id = m.m_product_id
    WHERE m.ad_client_id = $P{AD_CLIENT_ID}
      AND m.movementdate <= $P{EndDate} 
      AND hh.m_product_id = 1019435
),

-- Tồn kho ngao nâu (có thuộc tính)
ton_kho_ngao_nau AS (
    SELECT
        t.m_attribute_id,
        t.hsv_c_thuoctinh_id,
        SUM(CASE WHEN t.movementdate < $P{StartDate} THEN t.movementqty ELSE 0 END) AS dudau,
        SUM(CASE WHEN t.movementdate BETWEEN $P{StartDate} AND $P{EndDate} AND t.tang_giam = '+' THEN t.movementqty ELSE 0 END) AS sln,
        SUM(CASE WHEN t.movementdate BETWEEN $P{StartDate} AND $P{EndDate} AND t.tang_giam = '-' THEN -t.movementqty ELSE 0 END) AS slx,
        SUM(CASE WHEN t.movementdate <= $P{EndDate} THEN t.movementqty ELSE 0 END) AS ducuoi
    FROM giao_dich_ngao t
    GROUP BY t.m_attribute_id, t.hsv_c_thuoctinh_id
),

-- Tồn kho tổng (ngao trắng + ngao nâu)
ton_kho_ngao_tong AS (
    SELECT
        SUM(CASE WHEN t.movementdate < $P{StartDate} THEN t.movementqty ELSE 0 END) AS dudau,
        SUM(CASE WHEN t.movementdate BETWEEN $P{StartDate} AND $P{EndDate} AND t.tang_giam = '+' THEN t.movementqty ELSE 0 END) AS sln,
        SUM(CASE WHEN t.movementdate BETWEEN $P{StartDate} AND $P{EndDate} AND t.tang_giam = '-' THEN -t.movementqty ELSE 0 END) AS slx,
        SUM(CASE WHEN t.movementdate <= $P{EndDate} THEN t.movementqty ELSE 0 END) AS ducuoi
    FROM giao_dich_ngao_tong t
),

-- Nhập mua ngao nâu (có thuộc tính)
nhap_mua_ngao_nau AS (
    SELECT SUM(miv.movementqty) AS qty
    FROM m_inout mi 
    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id 
    JOIN m_attributeinstance ma ON ma.m_attributesetinstance_id = miv.m_attributesetinstance_id
    JOIN m_attributevalue mav ON mav.m_attributevalue_id = ma.m_attributevalue_id
    WHERE mi.ad_client_id = $P{AD_CLIENT_ID}
      AND miv.m_product_id = 1019435
      AND ma.m_attribute_id = 1000156
      AND mav.hsv_c_thuoctinh_id = 1000147
      AND mi.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND mi.docstatus IN ('CL','CO')
),

-- Nhập mua ngao tổng
nhap_mua_ngao_tong AS (
    SELECT SUM(miv.movementqty) AS qty
    FROM m_inout mi 
    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id 
    WHERE mi.ad_client_id = $P{AD_CLIENT_ID}
      AND miv.m_product_id = 1019435
      AND mi.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND mi.docstatus IN ('CL','CO')
),

-- Xuất bán ngao (kq41 trong query 2)
xuat_ban_ngao AS (
    SELECT
        SUM(CASE WHEN mav.hsv_c_thuoctinh_id = 1000147 THEN miv.movementqty ELSE 0 END) AS ngao_nau,
        SUM(CASE WHEN mav.hsv_c_thuoctinh_id = 1000148 THEN miv.movementqty ELSE 0 END) AS ngao_trang
    FROM m_inout mi
    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id
    JOIN m_product p ON p.m_product_id = miv.m_product_id
    JOIN m_attributeinstance ma ON ma.m_attributesetinstance_id = miv.m_attributesetinstance_id
    JOIN m_attributevalue mav ON mav.m_attributevalue_id = ma.m_attributevalue_id
    WHERE mi.ad_client_id = $P{AD_CLIENT_ID}
      AND mi.docstatus IN ('CL','CO')
      AND mi.issotrx = 'Y'
      AND mi.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND miv.m_product_id IN (1019435, 1019436)
      AND p.m_attributeset_id = 1000205
      AND mav.hsv_c_thuoctinh_id IN (1000147, 1000148)
),

-- Nhập kho từ sản xuất cho ngao (dùng cho kq6 query 2)
nhap_kho_ngao AS (
    SELECT
        SUM(civ.productionqty) AS qty,
        hh.hsv_loaimat_id,
        ci.c_campaign_id
    FROM m_production ci
    JOIN m_productionplan civ ON ci.m_production_id = civ.m_production_id
    JOIN m_product hh ON hh.m_product_id = civ.m_product_id
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND ci.docstatus IN ('CL','CO')
    GROUP BY hh.hsv_loaimat_id, ci.c_campaign_id
),

-- kq (chỉ tiêu 1–3) theo logic query 2
kq_ngao AS (
    -- 1: Tồn đầu kỳ
    SELECT 1 AS id,
           SUM(ngao_nau) AS ngao_nau,
           SUM(ngao_nl)  AS ngao_nl
    FROM (
        SELECT
            SUM(t.dudau) FILTER (
                WHERE t.m_attribute_id = 1000156
                  AND t.hsv_c_thuoctinh_id = 1000147
            ) AS ngao_nau,
            0 AS ngao_nl
        FROM ton_kho_ngao_nau t
        UNION ALL
        SELECT 0 AS ngao_nau, SUM(dudau) AS ngao_nl
        FROM ton_kho_ngao_tong
    ) k

    UNION ALL

    -- 2: Nhập mua trong kỳ
    SELECT 2 AS id,
           SUM(ngao_nau) AS ngao_nau,
           SUM(ngao_nl)  AS ngao_nl
    FROM (
        SELECT SUM(qty) AS ngao_nau, 0 AS ngao_nl FROM nhap_mua_ngao_nau
        UNION ALL
        SELECT 0 AS ngao_nau, SUM(qty) AS ngao_nl FROM nhap_mua_ngao_tong
    ) k

    UNION ALL

    -- 3: Tồn cuối kỳ
    SELECT 3 AS id,
           SUM(ngao_nau) AS ngao_nau,
           SUM(ngao_nl)  AS ngao_nl
    FROM (
        SELECT
            SUM(t.ducuoi) FILTER (
                WHERE t.m_attribute_id = 1000156
                  AND t.hsv_c_thuoctinh_id = 1000147
            ) AS ngao_nau,
            0 AS ngao_nl
        FROM ton_kho_ngao_nau t
        UNION ALL
        SELECT 0 AS ngao_nau, SUM(ducuoi) AS ngao_nl
        FROM ton_kho_ngao_tong
    ) k
),

-- kq5 theo logic query 2 (trừ xuất bán kq41)
kq5_ngao AS (
    SELECT
        5 AS id,
        -- Ngao nâu: tồn đầu + nhập mua - tồn cuối - xuất bán nâu
        (
            SUM(CASE
                WHEN k.id = 1 THEN k.ngao_nau
                WHEN k.id = 2 THEN k.ngao_nau
                WHEN k.id = 3 THEN -k.ngao_nau
            END)
            - COALESCE(MAX(x.ngao_nau), 0)
        ) AS ngao_nau,
        -- Ngao trắng: tồn đầu + nhập mua - tồn cuối - xuất bán trắng
        (
            SUM(CASE
                WHEN k.id = 1 THEN (k.ngao_nl - k.ngao_nau)
                WHEN k.id = 2 THEN (k.ngao_nl - k.ngao_nau)
                WHEN k.id = 3 THEN -(k.ngao_nl - k.ngao_nau)
            END)
            - COALESCE(MAX(x.ngao_trang), 0)
        ) AS ngao_trang
    FROM kq_ngao k
    LEFT JOIN xuat_ban_ngao x ON 1 = 1
    WHERE k.id BETWEEN 1 AND 3
),

-- kq6 theo logic query 2
kq6_ngao AS (
    SELECT
        6 AS id,
        COALESCE(SUM(qty) FILTER (
            WHERE hsv_loaimat_id = 1000128
              AND c_campaign_id IN (1000100, 1000104)
        ), 0) AS ngao_nau,
        COALESCE(SUM(qty) FILTER (
            WHERE hsv_loaimat_id = 1000129
              AND c_campaign_id IN (1000100, 1000104)
        ), 0) AS ngao_trang
    FROM nhap_kho_ngao
),

-- kq7 = II.09 theo đúng logic query 2
kq7_ngao AS (
    SELECT
        (
            MAX(CASE WHEN id = 6 THEN ngao_nau END)
            - MAX(CASE WHEN id = 5 THEN ngao_nau END) / 1.15
            - 0.08 * MAX(CASE WHEN id = 5 THEN ngao_trang END) / 1.15
        ) AS ngao_nau
    FROM (
        SELECT id, ngao_nau, ngao_trang FROM kq5_ngao
        UNION ALL
        SELECT id, ngao_nau, ngao_trang FROM kq6_ngao
    ) all_kq
),

-- ============================================================
-- CÁC CTE GỐC CỦA QUERY 1 (giữ nguyên)
-- ============================================================

giao_dich AS (
    SELECT
        ma.m_attribute_id,
        mav.hsv_c_thuoctinh_id,
        m.movementdate,
        m.movementqty,
        RIGHT(m.movementtype, 1) AS tang_giam
    FROM m_transaction m
    JOIN m_product hh ON hh.m_product_id = m.m_product_id
    JOIN m_attributeinstance ma ON ma.m_attributesetinstance_id = m.m_attributesetinstance_id
    JOIN m_attributevalue mav ON mav.m_attributevalue_id = ma.m_attributevalue_id
    WHERE m.ad_client_id = $P{AD_CLIENT_ID}
      AND m.movementdate <= $P{EndDate}
      AND hh.M_Product_ID = 1019435
),

giao_dich_2 AS (
    SELECT
        m.movementdate,
        m.movementqty,
        RIGHT(m.movementtype, 1) AS tang_giam
    FROM m_transaction m
    JOIN m_product hh ON hh.m_product_id = m.m_product_id
    WHERE m.ad_client_id = $P{AD_CLIENT_ID}
      AND m.movementdate <= $P{EndDate}
      AND hh.M_Product_ID = 1019435
),

chuyen_kho_2_9 AS (
    SELECT COALESCE(SUM(mmv.movementqty), 0) AS qty
    FROM m_movement mm
    JOIN m_movementline mmv ON mm.m_movement_id = mmv.m_movement_id
    WHERE mmv.ad_client_id = $P{AD_CLIENT_ID}
      AND mm.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND mm.docstatus IN ('CL', 'CO')
      AND mmv.M_Product_ID = 1019436
      AND mmv.M_Locator_ID = 1000303 AND mmv.M_Locator_ID = 1000301
),

nhap_mua_tt AS (
    SELECT SUM(miv.movementqty) AS qty
    FROM m_inout mi
    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id
    JOIN m_attributeinstance ma ON ma.m_attributesetinstance_id = miv.m_attributesetinstance_id
    JOIN m_attributevalue mav ON mav.m_attributevalue_id = ma.m_attributevalue_id
    WHERE mi.ad_client_id = $P{AD_CLIENT_ID}
      AND miv.M_Product_ID = 1019435
      AND ma.M_Attribute_ID = 1000156 AND mav.hsv_C_thuoctinh_ID = 1000147
      AND mi.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND mi.docstatus IN ('CL', 'CO')
),

nhap_mua_all AS (
    SELECT SUM(miv.movementqty) AS qty
    FROM m_inout mi
    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id
    WHERE mi.ad_client_id = $P{AD_CLIENT_ID}
      AND miv.M_Product_ID = 1019435
      AND mi.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND mi.docstatus IN ('CL', 'CO')
),

nhap_kho_2_9 AS (
    SELECT civ.productionqty AS qty, hh.hsv_loaimat_id, ci.c_campaign_id
    FROM m_production ci
    JOIN m_productionplan civ ON ci.m_production_id = civ.m_production_id
    JOIN m_product hh ON hh.m_product_id = civ.m_product_id
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND ci.docstatus IN ('CL', 'CO')
),

ton_kho_summary AS (
    SELECT
        SUM(CASE WHEN t.M_Attribute_ID = 1000156 AND t.hsv_C_thuoctinh_ID = 1000147 THEN t.movementqty END) FILTER (WHERE t.movementdate < $P{StartDate})  AS tdk_nau,
        SUM(CASE WHEN t.M_Attribute_ID = 1000156 AND t.hsv_C_thuoctinh_ID = 1000147 THEN t.movementqty END) FILTER (WHERE t.movementdate <= $P{EndDate}) AS tck_nau,
        SUM(t2.movementqty) FILTER (WHERE t2.movementdate < $P{StartDate})  AS tdk_trang_tong,
        SUM(t2.movementqty) FILTER (WHERE t2.movementdate <= $P{EndDate}) AS tck_trang_tong
    FROM giao_dich t
    FULL JOIN giao_dich_2 t2 ON FALSE
),

kq_1_4 AS (
    SELECT
        (SELECT tdk_nau FROM ton_kho_summary) AS t1_nau,
        (SELECT tdk_trang_tong - tdk_nau FROM ton_kho_summary) AS t1_trang,
        (SELECT qty FROM nhap_mua_tt) AS t2_nau,
        ((SELECT qty FROM nhap_mua_all) - (SELECT qty FROM nhap_mua_tt)) AS t2_trang,
        (SELECT tck_nau FROM ton_kho_summary) AS t3_nau,
        ((SELECT tck_trang_tong FROM ton_kho_summary) - (SELECT tck_nau FROM ton_kho_summary)) AS t3_trang,
        COALESCE(SUM(t.qty) FILTER (WHERE t.hsv_loaimat_ID = 1000128), 0) * 1.15 AS t4_nau,
        (SELECT qty FROM chuyen_kho_2_9) AS t4_trang
    FROM nhap_kho_2_9 t
    CROSS JOIN chuyen_kho_2_9 ck
),

kq5 AS (
    SELECT
        (t1_nau + t2_nau - t3_nau - t4_nau) AS nau,
        (t1_trang + t2_trang - t3_trang - t4_trang + t4_nau) AS trang
    FROM kq_1_4
),

kq6 AS (
    SELECT
        COALESCE(SUM(qty) FILTER (
            WHERE hsv_loaimat_ID = 1000128
              AND c_campaign_id IN (1000100, 1000101, 1000104)
        ), 0) AS nau,
        COALESCE(SUM(qty) FILTER (
            WHERE hsv_loaimat_ID = 1000129
              AND c_campaign_id IN (1000100, 1000101, 1000104)
        ), 0) AS trang
    FROM nhap_kho_2_9
),

filter_data as (
	SELECT id, SUM(qty) AS qty
	FROM (
		select 'I' as id, null as qty 
		union all
	    select 'I.01' AS id, SUM(miv.movementqty) AS qty
	    FROM m_inout mi
	    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id
	    JOIN hsv_lovansay hl ON hl.hsv_lovansay_id = miv.hsv_lovansay_id
	    WHERE hl.hsv_loailo_ID = 1000008
	      AND mi.issotrx = 'N' and mi.docstatus in ('CL','CO')
	      AND mi.ad_client_id = $P{AD_CLIENT_ID}
	      AND mi.dateacct BETWEEN $P{StartDate} AND $P{EndDate}

	    UNION ALL
	    
	    SELECT 'I.02', SUM(miv.movementqty)
	    FROM m_inout mi
	    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id
	    JOIN hsv_lovansay hl ON hl.hsv_lovansay_id = miv.hsv_lovansay_id
	    WHERE hl.hsv_loailo_id <> 1000008
	      AND mi.issotrx = 'N' and mi.docstatus in ('CL','CO')
	      AND mi.ad_client_id = $P{AD_CLIENT_ID}
	      AND mi.dateacct BETWEEN $P{StartDate} AND $P{EndDate}
		
	   	union all 
	    SELECT 'I.03', SUM(miv.movementqty)
	    FROM m_inout mi
	    JOIN m_inoutline miv ON mi.m_inout_id = miv.m_inout_id
	    JOIN hsv_lovansay hl ON hl.hsv_lovansay_id = miv.hsv_lovansay_id
	    WHERE hl.hsv_loailo_id <> 1000008
	      AND mi.issotrx = 'N' and mi.docstatus in ('CL','CO')
	      AND mi.ad_client_id = $P{AD_CLIENT_ID}
	      AND mi.dateacct BETWEEN $P{StartDate} AND $P{EndDate}
	      AND hl.dateto >= $P{StartDate} and hl.dateto <= $P{EndDate}

		union all 
		select 'I.04' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000631)
	    FROM nhatky_sx 

		union all 
		select 'I.05' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000632)
	    FROM nhatky_sx 
		
		union all 
		select 'I.06' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000633)
	    FROM nhatky_sx 
	    
		union all 
		select 'I.07', sum(movementqty) FILTER (
	    	where m_product_id in (1019437,1019436) and M_Locator_ID = 1000303
	    )
	    from chuyen_kho 

		union all 
		select 'I.08' as id, null as qty 

		union all 
		select 'II' as id, null as qty

		union all 
		select 'II.01' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000613)
	    FROM nhatky_sx 
	    
		union all 
		select 'II.02' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000614)
	    FROM nhatky_sx 
	    
	    UNION ALL
	    select 'II.03', sum(qty)
	    from (
	    	select 0 as qty 
	    	union all 
		    SELECT SUM(productionqty) FILTER (
		        WHERE c_campaign_id in (1000100,1000101)
		          AND M_AttributeSet_ID = 1000199
		          AND m_attributevalue_id in (1000866,1000867,1000868,1000873,1000874)
		    )
		    FROM nhap_kho_tt
		    union all 
		    SELECT SUM(productionqty) FILTER (
		        WHERE c_campaign_id in (1000100,1000101)
		          AND M_AttributeSet_ID = 1000199
		          AND m_attributevalue_id in (1000869,1000870,1000871,1000872)
		    )
		    FROM nhap_kho_tt
	    ) as k
	    
	    UNION all
	    select 'II.04', sum(qty) 
		from (
		   	select 0 as qty 
		    union all 
		   	select -1*SUM(qtyother/1.15) FILTER (WHERE hsv_sanpham_ID = 1000613)
	    	FROM nhatky_sx 
	    	union all 
			select -1*SUM(qtyother/1.15) FILTER (WHERE hsv_sanpham_ID = 1000614)
	    	FROM nhatky_sx 
			union all 
			select -1*SUM(qtyother/1.15) FILTER (WHERE hsv_sanpham_ID = 1000630)
	    	FROM nhatky_sx 
			union all 
		    select SUM(productionqty) FILTER (
		        WHERE c_campaign_id IN (1000104)
		          AND m_attributeset_id IN (1000199,1000206,1000198)
		    )
		    FROM nhap_kho		  
		) as k
		
		union all 
		select 'II.05', sum(qty)
		FROM (
			select 0 as qty
			union all 
			select SUM(productionqty) FILTER (
		        WHERE c_campaign_id IN (1000104)
		          AND m_attributeset_id IN (1000199,1000206,1000198)
		    )
		    FROM nhap_kho
		    union all
		   	select SUM(qtyother/1.15) FILTER (WHERE hsv_sanpham_ID = 1000630)
	    	FROM nhatky_sx 
	    	union all 
		    select -1*sum(qty) 
			from (
			   	select 0 as qty 
			    union all 
			   	select -1*SUM(qtyother/1.15) FILTER (WHERE hsv_sanpham_ID = 1000613)
		    	FROM nhatky_sx 
		    	union all
				select -1*SUM(qtyother/1.15) FILTER (WHERE hsv_sanpham_ID = 1000614)
		    	FROM nhatky_sx 
				union all 
			    select SUM(productionqty) FILTER (
			        WHERE c_campaign_id IN (1000104)
			          AND m_attributeset_id IN (1000199,1000206,1000198)
			    )
			    FROM nhap_kho		  
			) as k
		) as j
		
		union all 
		select 'II.06' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000609)
	    FROM nhatky_sx 
		
		union all 
		select 'II.07' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000610)
	    FROM nhatky_sx 
		
		union all 
		select 'II.08' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000611)
	    FROM nhatky_sx 
		
		union all

        -- II.09: lấy đúng từ kq7_ngao.ngao_nau (= logic kq7 query 2)
		select 'II.09' as id, (SELECT ngao_nau FROM kq7_ngao) AS qty
	    
	    union all 
	   	select 'II.10' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000612)
	    FROM nhatky_sx 
		
	    union all 
		select 'II.11' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000620)
	    FROM nhatky_sx 
	 
	    union all 
		select 'II.12' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000626)
	    FROM nhatky_sx 

		union all 
		select 'III' as id, null as qty
	    UNION ALL
	    SELECT 'III.01',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id = 1000104
	                 AND m_attributeset_id IN (1000199,1000206,1000198)
	           )
	    FROM nhap_kho
	    
		union all 
		select 'III.02' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000618)
	    FROM nhatky_sx 
	    
		union all 
		select 'IV' as id, null as qty
	    union all
		SELECT 'IV.01',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id = 1000104
	                 AND m_attributeset_id IN (1000199,1000206,1000198)
	           )
	    FROM nhap_kho
	    union all 
		select 'IV.02' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000619)
	    FROM nhatky_sx 
	    
	    UNION all
	    select 'V' as id, null as qty
	    union all
	    SELECT 'V.01',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id = 1000104
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000866,1000867,1000868,1000873,1000874)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'V.02',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id = 1000104
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000869,1000870,1000871,1000872)
	           )
	    FROM nhap_kho_tt
	 	union all 
	    SELECT 'V.03',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id = 1000104
	                 AND m_attributeset_id IN (1000206,1000198)
	           )
	    FROM nhap_kho
	    union all 
	    SELECT 'V.04',
	           SUM(productionqty) FILTER (
	               WHERE C_Campaign_ID = 1000105
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000866,1000867,1000868,1000873,1000874)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'V.05',
	           SUM(productionqty) FILTER (
	               WHERE C_Campaign_ID = 1000105
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id IN (1000869,1000870,1000871,1000872)
	           )
	    FROM nhap_kho_tt
	   	union all 
	    SELECT 'V.06',
	           SUM(productionqty) FILTER (
	               WHERE C_Campaign_ID = 1000105
	                 AND m_attributeset_id in (1000206,1000198)
	           )
