	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000879,1000881)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VIII.10',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000100,1000101)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000866,1000867,1000868,1000873,1000874)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VIII.11',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000100,1000101)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000869,1000870,1000871,1000872)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VIII.12',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000100,1000101)
	                 AND m_attributeset_id in (1000206,1000198)  
	           )
	    FROM nhap_kho
	    union all 
	    SELECT 'X' AS code, NULL AS qty
		UNION ALL 
		SELECT 'X.01',
		       SUM(qtyentered) FILTER (
		           WHERE M_AttributeValue_ID IN (1000882,1000886,1000889,1000894)
		             AND m_attributeset_id IN (1000199,1000200)   
		       )
		FROM xuat_ban_tt
		UNION ALL 
		SELECT 'X.02',
		       SUM(qtyentered) FILTER (
		           WHERE m_attributevalue_id IN (1000892,1000893)
		             AND m_attributeset_id IN (1000199,1000200)   
		       )
		FROM xuat_ban_tt
		UNION ALL    
		SELECT 'X.03',
		       SUM(qtyentered) FILTER (
		           WHERE M_AttributeValue_ID IN (1000876,1000877,1000890,1000896)
		             AND m_attributeset_id IN (1000199,1000200)   
		       )
		FROM xuat_ban_tt
		UNION ALL    
		SELECT 'X.04',
		       SUM(qtyentered) FILTER (
		           WHERE M_AttributeValue_ID = 1000888
		             AND m_attributeset_id IN (1000199,1000200)   
		       )
		FROM xuat_ban_tt
		UNION ALL    
		SELECT 'X.05',
		       SUM(qtyentered) FILTER (
		           WHERE M_AttributeValue_ID IN (1000884,1000879,1000881,1000885)
		             AND m_attributeset_id IN (1000199,1000200)   
		       )
		FROM xuat_ban_tt
		UNION ALL 
		SELECT 'X.06',
		       SUM(qtyentered) FILTER (
		           WHERE m_attributevalue_id in (1000883,1000875)
		             AND m_attributeset_id IN (1000199,1000200)   
		       )
		FROM xuat_ban_tt
		UNION ALL 
		SELECT 'X.07',
		       SUM(qtyentered) FILTER (
		           WHERE m_attributevalue_id in (1000878,1000887)
		             AND m_attributeset_id IN (1000199,1000200)  
		       )
		FROM xuat_ban_tt
		UNION ALL 
		SELECT 'X.08',
		       SUM(qtyentered) FILTER (
		           WHERE M_AttributeSet_ID = 1000199 
		           AND M_AttributeValue_ID = 1000910
		       )
		FROM xuat_ban_tt
		UNION ALL 
		SELECT 'X.09',
		       SUM(qtyentered) FILTER (
		           WHERE m_attributeset_id IN (1000199,1000200,1000202,1000208) 
		       )
		FROM xuat_ban
		union all 
		select 'X.10' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000623)
	    FROM nhatky_sx 
		union all 
		select 'XI', null 
		union all 
		select 'XI.01', 
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND m_attributeset_id in (1000200,1000201)
	                 AND M_AttributeValue_ID = 1000926
	           )
	    FROM nhap_kho_tt
	    union all 
		select 'XI.02', 
	           SUM(productionqty) FILTER (
