	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND M_AttributeValue_ID = 1000876
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.05',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND M_AttributeValue_ID = 1000888
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.06',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000884,1000885)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.07',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000883,1000875)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.08',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000878,1000887)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VI.09',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000105,1000104)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000879,1000881)
	           )
	    FROM nhap_kho_tt
	    union ALL
	    SELECT 'VII', null as qty
	    UNION all 
	    SELECT 'VII.01',
	           SUM(productionqty) FILTER (
	               WHERE M_Locator_ID = 1000299
	                 AND m_attributeset_id IN (1000199,1000206,1000198,1000200,1000201,1000202,1000203,1000208)
	           )
	    FROM nhap_kho
	    union all 
	    select 'VII.02', 
	    	SUM(QtyInternalUse) FILTER (
	    		WHERE m_attributeset_id IN (1000199,1000206,1000198,1000200,1000201,1000202,1000203,1000208)
	    		AND M_Locator_ID = 1000299
	    	)
		FROM xuat_kho
		union all 
		select 'VII.03',
		 SUM(qtyentered) FILTER (
		 	WHERE m_attributeset_id IN (1000199,1000200,1000202,1000208)
	    		AND M_Locator_ID = 1000299
		 )
		FROM xuat_ban 
		union ALL
	    select 'VII.04' as id, SUM(qtyentered) FILTER (WHERE M_Product_ID = 1019844)
	    FROM nhap_mua  
	    union ALL
	    select 'VII.05' as id, SUM(qtyentered) FILTER (
		    WHERE m_attributeset_id IN (1000199,1000200,1000202,1000208) 
		    AND M_Locator_ID = 1000299
	    )
	    FROM xuat_ban  
	    union ALL
	    select 'VII.06' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000624)
	    FROM nhatky_sx 
	    union ALL
	    select 'VII.07' as id, SUM(qtyother) FILTER (WHERE hsv_sanpham_ID = 1000629)
	    FROM nhatky_sx 
	    union ALL
	    SELECT 'VIII', null as qty
	    union all 
	    SELECT 'VIII.01',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000100,1000101)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000882,1000886,1000889)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VIII.02',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000100,1000101)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000892,1000893)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VIII.03',
	           SUM(productionqty) FILTER (
	               WHERE c_campaign_id in (1000100,1000101)
	                 AND M_AttributeSet_ID = 1000199
	                 AND m_attributevalue_id in (1000877,1000890)
	           )
	    FROM nhap_kho_tt
	    union all 
	    SELECT 'VIII.04',
	           SUM(productionqty) FILTER (
