	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="C_BankAccount_ID" class="java.lang.Integer"/>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="C_BPartner_ID" class="java.lang.Integer"/>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[WITH payment_base AS (
    SELECT
        pa.c_bankaccount_id,
        pa.datetrx,
        pa.documentno,
        pa.payamt,
        pa.description,
        pa.c_invoice_id,
        pa.c_bpartner_id,
        pa.c_charge_id,
        doc.docbasetype,
        cca.ch_expense_acct
    FROM c_payment pa
    JOIN c_doctype doc
        ON pa.c_doctype_id = doc.c_doctype_id
        AND doc.docbasetype IN ('APP', 'ARR')
    LEFT JOIN c_charge_acct cca
        ON pa.c_charge_id = cca.c_charge_id
    WHERE pa.docstatus IN ('CO', 'CL')
      AND pa.posted = 'Y'
      AND (pa.c_bpartner_id = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
      AND (pa.ad_orgtrx_id  = $P{AD_Org_ID}     OR $P{AD_Org_ID}     IS NULL)
      AND (pa.c_currency_id = $P{C_Currency_ID}  OR $P{C_Currency_ID} IS NULL)
      AND pa.ad_client_id   = $P{AD_CLIENT_ID}
      -- ⚠️ Không lọc ngày ở đây — để tính được số dư đầu kỳ
),

raw_transactions AS (

    SELECT
        pb.c_bankaccount_id,
        pb.datetrx,
        pb.documentno,
        kh.name,
        COALESCE(
            pb.description,
            (SELECT inv.documentno FROM c_invoice inv
             WHERE inv.c_invoice_id = pb.c_invoice_id LIMIT 1),
            ''
        ) AS description,
        CASE WHEN pb.docbasetype = 'APP' THEN -pb.payamt ELSE  pb.payamt END AS grandtotal,
        CASE WHEN pb.docbasetype = 'ARR' THEN  pb.payamt ELSE  0          END AS psno,
        CASE WHEN pb.docbasetype = 'APP' THEN  pb.payamt ELSE  0          END AS psco
    FROM payment_base pb
    JOIN c_bpartner kh ON kh.c_bpartner_id = pb.c_bpartner_id
    WHERE pb.c_bankaccount_id = $P{C_BankAccount_ID}

    UNION ALL

    SELECT
        acct.c_bankaccount_id,
        pb.datetrx,
        pb.documentno,
        kh.name,
        pb.description,
        CASE WHEN pb.docbasetype = 'APP' THEN  pb.payamt ELSE -pb.payamt END AS grandtotal,
        CASE WHEN pb.docbasetype = 'APP' THEN  pb.payamt ELSE  0          END AS psno,
        CASE WHEN pb.docbasetype = 'APP' THEN  0          ELSE  pb.payamt END AS psco
    FROM payment_base pb
    JOIN c_bankaccount_acct acct
        ON acct.b_asset_acct      = pb.ch_expense_acct
        AND acct.c_bankaccount_id = $P{C_BankAccount_ID}
    LEFT JOIN c_bpartner kh ON kh.c_bpartner_id = pb.c_bpartner_id
    WHERE pb.c_charge_id IS NOT NULL
),

-- Áp dụng điều chỉnh dấu theo loại tài khoản (1 lần duy nhất)
adjusted_transactions AS (
    SELECT
        r.datetrx,
        r.documentno,
        r.name,
        r.description,
        CASE WHEN LEFT(ba.accountno, 1) = '3'
             THEN -r.grandtotal
             ELSE  r.grandtotal
        END AS grandtotal,
        r.psno,
        r.psco
    FROM raw_transactions r
    JOIN c_bankaccount ba ON ba.c_bankaccount_id = r.c_bankaccount_id
),

-- Tổng tất cả giao dịch TRƯỚC kỳ báo cáo
opening_balance AS (
    SELECT COALESCE(SUM(grandtotal), 0) AS ob_amount
    FROM adjusted_transactions
    WHERE datetrx < $P{StartDate}
)

-- ── Dòng số dư đầu kỳ ──────────────────────────────────────────────────────
SELECT
    0                   AS sort_order,
    null       AS datetrx,
    ''                  AS documentno,
    ''                  AS name,
    'Số dư đầu kỳ'      AS description,
    ob.ob_amount        AS grandtotal,
    NULL::numeric       AS psno,
    NULL::numeric       AS psco,
    ob.ob_amount        AS so_du          -- cột số dư
FROM opening_balance ob

UNION ALL

-- ── Giao dịch trong kỳ + số dư lũy kế ─────────────────────────────────────
SELECT
    1                   AS sort_order,
    t.datetrx,
    t.documentno,
    t.name,
    t.description,
    t.grandtotal,
    t.psno,
    t.psco,
    ob.ob_amount + SUM(t.grandtotal) OVER (
        ORDER BY t.datetrx, t.documentno
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    )                   AS so_du          -- cộng dồn từ đầu kỳ
FROM adjusted_transactions t
CROSS JOIN opening_balance ob
WHERE t.datetrx BETWEEN $P{StartDate} AND $P{EndDate}

ORDER BY sort_order, datetrx, documentno;]]>
	</queryString>
	<field name="sort_order" class="java.lang.Integer">
