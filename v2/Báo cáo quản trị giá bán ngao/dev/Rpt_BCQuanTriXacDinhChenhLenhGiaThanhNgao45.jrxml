                             join c_invoice hd on hd.c_invoice_id=cil.c_invoice_id and hd.docstatus in ('CO','CL') and hd.C_DocType_ID=1001326 and hd.dateacct<=$P{EndDate} and hd.dateacct>=$P{StartDate}
                             join Fact_Acct f on cil.c_invoice_id=f.record_id and cil.c_invoiceline_id=f.line_id and f.ad_table_id=318 and f.amtacctcr<>0 and f.c_currency_id=100
                             join m_product hh on cil.m_product_id=hh.m_product_id and hh.M_AttributeSet_ID in (1000199) and  hh.hsv_C_thuoctinh_ID in (1000161)
                             join (select tt.m_attributesetinstance_id from m_attributeinstance tt
