              group by t.ct
      
                    
        ) as kq
        join hsv_giathanhvan bc on bc.value=kq.ct and AD_Client_ID in ($P{AD_CLIENT_ID})
        order by  cast(bc.value as integer) asc
        
) as kq1
join hsv_giathanhvan bc on bc.value=kq1.ct and AD_Client_ID in ($P{AD_CLIENT_ID})
where kq1.cl<>0 and kq1.b='1'
group by bc.description,bc.value,bc.name]]>
