	<parameter name="C_BPartner_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1000046]]></defaultValueExpression>
	</parameter>
	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date(100,0,1)]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="EndDate" class="java.util.Date"/>
	<parameter name="C_Activity_ID" class="java.lang.Integer"/>
	<parameter name="C_Campaign_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[WITH fa_filtered AS (
    -- Bước 1: Lọc dữ liệu thô (Dùng chung cho cả đầu kỳ và trong kỳ)
    SELECT 
        fa.dateacct, fa.amtacctdr, fa.amtacctcr, fa.account_id,
        fa.description, bp.value AS bp_value, fa.ad_table_id, fa.record_id  
    FROM Fact_Acct fa
    INNER JOIN C_ElementValue ev ON fa.account_id = ev.c_elementvalue_id
    LEFT JOIN C_BPartner bp ON fa.c_bpartner_id = bp.c_bpartner_id
    WHERE fa.AD_Client_ID = $P{AD_CLIENT_ID}
      AND ev.Value LIKE '331%'    
      AND fa.c_currency_id = $P{C_Currency_ID}
      AND (fa.C_BPartner_ID = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
       AND (fa.C_Activity_ID = $P{C_Activity_ID} OR $P{C_Activity_ID} IS NULL)
      AND (fa.C_Campaign_ID = $P{C_Campaign_ID} OR $P{C_Campaign_ID} IS NULL)
      AND fa.dateacct <= $P{EndDate}
),

opening_balance AS (
    -- Bước 2: CODE RIÊNG TÍNH SỐ DƯ ĐẦU KỲ
    -- Chỉ lấy các phát sinh TRƯỚC ngày bắt đầu
    SELECT 
        SUM(amtacctcr - amtacctdr) AS openningbal
    FROM fa_filtered
    WHERE dateacct < $P{StartDate}
)

select * from opening_balance ]]>
	</queryString>
	<field name="openningbal" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="openningbal"/>
		<property name="com.jaspersoft.studio.field.label" value="openningbal"/>
	</field>
	<variable name="TOTALS" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{openningbal}]]></variableExpression>
		<initialValueExpression><![CDATA[new BigDecimal("0")]]></initialValueExpression>
	</variable>
