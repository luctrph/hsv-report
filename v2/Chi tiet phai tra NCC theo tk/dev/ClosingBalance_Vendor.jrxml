	<parameter name="C_BPartner_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[new Integer(1000028)]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="C_Activity_ID" class="java.lang.Integer"/>
	<parameter name="C_Campaign_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[-- Bước 1: Lọc dữ liệu thô từ Fact_Acct (Chỉ lấy các cột cần thiết)
WITH fa_filtered AS (
    SELECT 
        fa.dateacct, fa.amtacctdr, fa.amtacctcr, fa.account_id,
        fa.description, bp.value AS bp_value, fa.ad_table_id, fa.record_id  
    FROM Fact_Acct fa
    INNER JOIN C_ElementValue ev ON fa.account_id = ev.c_elementvalue_id
    LEFT JOIN C_BPartner bp ON fa.c_bpartner_id = bp.c_bpartner_id
    WHERE fa.AD_Client_ID = $P{AD_CLIENT_ID}
      AND ev.Value LIKE '331%'    
      AND fa.c_currency_id = $P{C_Currency_ID}
      AND fa.dateacct <= $P{EndDate}
      AND (fa.C_BPartner_ID = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
      AND (fa.C_Activity_ID = $P{C_Activity_ID} OR $P{C_Activity_ID} IS NULL)
      AND (fa.C_Campaign_ID = $P{C_Campaign_ID} OR $P{C_Campaign_ID} IS NULL)
)

-- Bước 2: TÁCH RIÊNG TÍNH SỐ DƯ ĐẦU KỲ (Siêu nhanh vì không Join bảng Document)

  select      SUM(amtacctcr - amtacctdr) AS cloase_amt
    FROM fa_filtered
    
]]>
	</queryString>
	<field name="cloase_amt" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="cloase_amt"/>
		<property name="com.jaspersoft.studio.field.label" value="cloase_amt"/>
	</field>
