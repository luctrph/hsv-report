	</parameter>
	<parameter name="C_Activity_ID" class="java.lang.Integer"/>
	<parameter name="C_Campaign_ID" class="java.lang.Integer"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[-- Bước 1: Lọc dữ liệu thô từ Fact_Acct (Chỉ lấy các cột cần thiết)
WITH fa_filtered AS (
    SELECT 
        fa.dateacct, fa.amtacctdr, fa.amtacctcr, fa.account_id,
        fa.description, bp.value AS bp_value, fa.ad_table_id, fa.record_id  
    FROM Fact_Acct fa
    INNER JOIN C_ElementValue ev ON fa.account_id = ev.c_elementvalue_id
    LEFT JOIN C_BPartner bp ON fa.c_bpartner_id = bp.c_bpartner_id
    WHERE fa.AD_Client_ID = $P{AD_CLIENT_ID}
      AND ev.Value LIKE '331%'    
      AND fa.c_currency_id = $P{C_Currency_ID}
      AND fa.dateacct <= $P{EndDate}
      AND (fa.C_BPartner_ID = $P{C_BPartner_ID} OR $P{C_BPartner_ID} IS NULL)
      AND (fa.C_Activity_ID = $P{C_Activity_ID} OR $P{C_Activity_ID} IS NULL)
      AND (fa.C_Campaign_ID = $P{C_Campaign_ID} OR $P{C_Campaign_ID} IS NULL)
),

-- Bước 2: TÁCH RIÊNG TÍNH SỐ DƯ ĐẦU KỲ (Siêu nhanh vì không Join bảng Document)
opening_balance AS (
    SELECT 
        SUM(amtacctcr - amtacctdr) AS opening_amt
    FROM fa_filtered
    WHERE dateacct < $P{StartDate}
),

-- Bước 3: Chỉ Join lấy chi tiết chứng từ cho những dòng phát sinh TRONG KỲ
base_period AS (
    SELECT fa.*, doc.documentno, doc.ten_loai
    FROM (SELECT * FROM fa_filtered WHERE dateacct >= $P{StartDate}) fa
    INNER JOIN (
        SELECT a_asset_addition_id AS id, 53137 AS tid, documentno, 'Tăng tài sản' AS ten_loai FROM A_Asset_Addition WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT a_asset_disposed_id, 53127, documentno, 'Thanh lý tài sản' FROM A_Asset_Disposed WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT a_depreciation_entry_id, 53121, documentno, 'Khấu hao' FROM A_Depreciation_Entry WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT c_bankstatement_id, 392, documentno, 'Báo có/nợ NH' FROM C_BankStatement WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT c_cash_id, 407, documentno, 'Thu/chi TM' FROM C_Cash WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT c_invoice_id, 318, documentno, 'Hóa đơn' FROM C_Invoice WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT c_payment_id, 335, documentno, 'Thanh toán' FROM C_Payment WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT gl_journal_id, 224, documentno, 'Phiếu kế toán' FROM GL_Journal WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT m_inout_id, 319, documentno, 'Nhập/Xuất kho' FROM M_InOut WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT m_inventory_id, 321, documentno, 'Kiểm kê' FROM M_Inventory WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT m_matchinv_id, 472, documentno, 'Khớp hóa đơn' FROM M_MatchInv UNION ALL
        SELECT m_matchpo_id, 473, documentno, 'Khớp đơn mua' FROM M_MatchPO UNION ALL
        SELECT m_movement_id, 323, documentno, 'Điều chuyển kho' FROM M_Movement WHERE docstatus IN ('CO','CL') UNION ALL
        SELECT m_production_id, 325, documentno, 'Sản xuất' FROM M_Production WHERE docstatus IN ('CO','CL')
    ) doc ON fa.record_id = doc.id AND fa.ad_table_id = doc.tid
)

-- Bước 4: Hiển thị và cộng dồn số dư
SELECT 
    ngay, loai_ct, soct, noidung, psn, psc,
    -- Số dư lũy kế = Dư đầu kỳ + Tổng (Có - Nợ) đến dòng hiện tại
    (SELECT COALESCE(opening_amt, 0) FROM opening_balance) + 
    SUM(psc - psn) OVER (ORDER BY ngay, soct ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS ps_luy_ke
FROM (
    SELECT 
        dateacct AS ngay, 
        ten_loai AS loai_ct, 
        COALESCE(documentno,'') AS soct,
        description AS noidung, 
        amtacctdr AS psn, 
        amtacctcr AS psc
    FROM base_period
) final
ORDER BY ngay, soct;]]>
	</queryString>
	<field name="ngay" class="java.sql.Timestamp">
		<property name="com.jaspersoft.studio.field.name" value="ngay"/>
		<property name="com.jaspersoft.studio.field.label" value="ngay"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="fact_acct"/>
	</field>
	<field name="loai_ct" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="loai_ct"/>
		<property name="com.jaspersoft.studio.field.label" value="loai_ct"/>
	</field>
	<field name="soct" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="soct"/>
		<property name="com.jaspersoft.studio.field.label" value="soct"/>
	</field>
	<field name="noidung" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="noidung"/>
		<property name="com.jaspersoft.studio.field.label" value="noidung"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="fact_acct"/>
	</field>
	<field name="psn" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="psn"/>
		<property name="com.jaspersoft.studio.field.label" value="psn"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="fact_acct"/>
	</field>
	<field name="psc" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="psc"/>
		<property name="com.jaspersoft.studio.field.label" value="psc"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="fact_acct"/>
	</field>
	<field name="ps_luy_ke" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="ps_luy_ke"/>
		<property name="com.jaspersoft.studio.field.label" value="ps_luy_ke"/>
	</field>
	<variable name="OPENBAL" class="java.math.BigDecimal" incrementType="Group" incrementGroup="group2">
		<variableExpression><![CDATA[$V{OPENBAL}]]></variableExpression>
