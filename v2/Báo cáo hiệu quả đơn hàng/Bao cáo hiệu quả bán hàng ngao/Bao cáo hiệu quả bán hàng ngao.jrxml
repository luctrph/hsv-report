				</textElement>
				<text><![CDATA[Nội dung]]></text>
			</staticText>
			<staticText>
				<reportElement x="212" y="0" width="58" height="30" uuid="85893889-c10f-4347-ba70-67acf5a81fb7">
					<property name="com.jaspersoft.studio.spreadsheet.connectionID" value="e6258301-f5f2-418f-9de6-a17a59d18fb7"/>
				</reportElement>
				<box leftPadding="2" rightPadding="2">
					<pen lineWidth="0.5"/>
