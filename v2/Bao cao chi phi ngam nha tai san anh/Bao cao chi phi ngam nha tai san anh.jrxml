<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Bao cao chi phi ngam nha tai san anh" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="33bdff4f-2c45-425a-8413-0def9a1b3806">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="psql"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="StartDate" class="java.util.Date"/>
	<parameter name="EndDate" class="java.util.Date"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH nhatky_sx AS (
    SELECT nkl.hsv_sanpham_id, nkl.qtyother  
    FROM hsv_nhatkysx nk
    JOIN hsv_nhatkysxline nkl 
        ON nk.hsv_nhatkysx_id = nkl.hsv_nhatkysx_id 
    WHERE nk.ad_client_id = $P{AD_CLIENT_ID} 
      AND nk.dateacct BETWEEN $P{StartDate} AND $P{EndDate}
),

nhatky_agg AS (
    SELECT
        SUM(qtyother) FILTER (WHERE hsv_sanpham_id = 1000613) AS soc1,
        SUM(qtyother) FILTER (WHERE hsv_sanpham_id = 1000614) AS soc2,
        SUM(qtyother) FILTER (WHERE hsv_sanpham_id = 1000611) AS xoc
    FROM nhatky_sx
),

movement AS (
    SELECT SUM(mml.movementqty) AS qty
    FROM m_movement mm 
    JOIN m_movementline mml 
        ON mm.m_movement_id = mml.m_movement_id 
    WHERE mm.ad_client_id = $P{AD_CLIENT_ID}
      AND mm.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND mm.docstatus IN ('CL','CO')
      AND mml.m_product_id IN (1019436,1019437) 
      AND mml.m_locator_id = 1000303
      AND mml.m_locatorto_id IN (1000300,1000299)
),

nlsx AS (
    SELECT SUM(nll.hsv_tapchat) AS qty
    FROM hsv_nlsx nl
    JOIN hsv_nlsxline nll 
        ON nl.hsv_nlsx_id = nll.hsv_nlsx_id 
    WHERE nl.ad_client_id = $P{AD_CLIENT_ID} 
      AND nll.dateacct  BETWEEN $P{StartDate} AND $P{EndDate}
     
),

production AS (
    SELECT
        -- ✅ chỉ tiêu 2.4 thêm điều kiện AttributeSet
        SUM(civ.productionqty) FILTER (
            WHERE civ.m_product_id NOT IN (1019489,1019491,1019490)
              AND hh.m_attributeset_id = 1000198
        ) AS qty_loi,
        
        -- giữ nguyên
        SUM(civ.productionqty) FILTER (
            WHERE civ.m_product_id = 1019489
        ) AS qty_chuyen
    FROM m_production ci 
    JOIN m_productionplan civ 
        ON ci.m_production_id = civ.m_production_id 
    join m_product hh on hh.m_product_id = civ.m_product_id 
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.movementdate BETWEEN $P{StartDate} AND $P{EndDate}
      AND ci.c_campaign_id IN (1000104,1000100)
)

SELECT 1 as id, '1' as stt ,'Chi phí ngâm nhã nuôi lưu' as noidung,null as dvt,  NULL::numeric as qty,NULL::numeric as dg,NULL::numeric as tt

UNION ALL
SELECT 2, '1.1','Ngao ngâm nhã chuyển về công ty', 'kg', qty,2000, qty*2000
FROM movement

UNION ALL
SELECT 3, '1.2','Số lượng ngao vỡ tạp chất (đánh giá KCS)','kg', coalesce(qty,0),2000, qty*2000 
FROM nlsx

UNION ALL
SELECT 4, '2','Chi phí phát sinh tại thuỷ sản',null,  NULL::numeric,NULL::numeric,NULL::numeric

UNION ALL
SELECT 5, '2.1','Ngao NL xử lý lại (sốc 1)','kg', coalesce(soc1,0),100, soc1*100
FROM nhatky_agg

UNION ALL
SELECT 6, '2.2','Ngao NL xử lý lại (sốc 2)','kg', coalesce(soc2,0),100, soc2*100
FROM nhatky_agg

UNION ALL
SELECT 7, '2.3','Ngao NL xử lý lại (xóc ngao)','kg', coalesce(xoc,0),100, xoc*100
FROM nhatky_agg

UNION ALL
SELECT 8, '2.4','Ngao TP không đạt đơn hàng (tạm, trộn)','kg', coalesce(qty_loi,0),1500, qty_loi*1500
FROM production

UNION ALL
SELECT 9, '2.5','Ngao TP chuyển ngao thịt', 'kg', coalesce(qty_chuyen,0),10000, qty_chuyen*10000
FROM production

UNION ALL
SELECT 10, '3','Chi phí tại san anh', null,NULL::numeric,NULL::numeric,NULL::numeric]]>
	</queryString>
