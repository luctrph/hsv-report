	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="psql"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="M_Product_ID" class="java.lang.Integer"/>
	<parameter name="M_Product_Category_ID" class="java.lang.Integer"/>
	<parameter name="M_AttributeSet_ID" class="java.lang.Integer"/>
	<parameter name="M_Locator_ID" class="java.lang.Integer"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    
	CASE 
        WHEN $P{AD_Org_ID} IS NOT NULL 
        THEN org.name 
    END AS bp,

	CASE 
        WHEN $P{M_Product_ID} IS NOT NULL 
        THEN p.value || ' - ' || p.name 
    END AS sanpham,

    CASE 
        WHEN $P{M_Product_Category_ID} IS NOT NULL 
        THEN pc.name 
    END AS nhomsanpham,

    CASE 
        WHEN $P{M_AttributeSet_ID} IS NOT NULL 
        THEN mas.name 
    END AS attributeset,

    CASE 
        WHEN $P{M_Locator_ID} IS NOT NULL 
        THEN l.value || ' - ' || w.name 
    END AS vitrikho

FROM m_product p
LEFT JOIN m_product_category pc
       ON pc.m_product_category_id = $P{M_Product_Category_ID}

LEFT JOIN m_attributeset mas
       ON mas.m_attributeset_id = $P{M_AttributeSet_ID}


LEFT JOIN m_locator l  ON l.m_locator_id = $P{M_Locator_ID}
LEFT JOIN m_warehouse w ON w.m_warehouse_id = l.m_warehouse_id
LEFT JOIN ad_org org on org.ad_org_id = $P{AD_Org_ID}

WHERE p.ad_client_id = $P{AD_CLIENT_ID}
  AND ($P{M_Product_ID} IS NULL OR p.m_product_id = $P{M_Product_ID})
LIMIT 1;]]>
	</queryString>
