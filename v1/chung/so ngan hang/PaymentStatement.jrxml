	<queryString language="SQL">
		<![CDATA[SELECT acc.name, ao.name as org_name, cb.name as partner_name
FROM c_bankaccount acc
left join ad_org ao on ao.ad_org_id = $P{AD_Org_ID}
left join c_bpartner cb on cb.c_bpartner_id = $P{C_BPartner_ID}
WHERE acc.c_bankaccount_id = $P{C_BankAccount_ID}
and acc.ad_client_id = $P{AD_CLIENT_ID}]]>
	</queryString>
