	</parameter>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="Account_ID" class="java.lang.Integer"/>
	<parameter name="DateAcct2" class="java.util.Date"/>
	<parameter name="DateAcct1" class="java.util.Date"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="C_BP_Group_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    ev.value AS Accountvalue,
    bp.value AS value,
    bp.name  AS name,

    /* Dư đầu */
    SUM(
        CASE
            WHEN fa.dateacct < $P{DateAcct1} THEN
                CASE
                    WHEN ev.accounttype IN ('A','E')
                        THEN fa.amtacctdr - fa.amtacctcr
                    ELSE
                        -(fa.amtacctdr - fa.amtacctcr)
                END
            ELSE 0
        END
    ) AS dudau,

    /* Phát sinh Có */
    SUM(
        CASE
            WHEN fa.dateacct BETWEEN $P{DateAcct1} AND $P{DateAcct2}
                THEN fa.amtacctcr
            ELSE 0
        END
    ) AS psco,

    /* Phát sinh Nợ */
    SUM(
        CASE
            WHEN fa.dateacct BETWEEN $P{DateAcct1} AND $P{DateAcct2}
                THEN fa.amtacctdr
            ELSE 0
        END
    ) AS psno,

    /* Dư cuối */
    SUM(
        CASE
            WHEN fa.dateacct <= $P{DateAcct2} THEN
                CASE
                    WHEN ev.accounttype IN ('A','E')
                        THEN fa.amtacctdr - fa.amtacctcr
                    ELSE
                        -(fa.amtacctdr - fa.amtacctcr)
                END
            ELSE 0
        END
    ) AS ducuoi

FROM Fact_Acct fa
JOIN C_ElementValue ev
    ON ev.C_ElementValue_ID = fa.Account_ID
JOIN C_BPartner bp
    ON bp.C_BPartner_ID = fa.C_BPartner_ID
   AND bp.AD_Client_ID = $P{AD_CLIENT_ID}
   AND (bp.C_BP_Group_ID = $P{C_BP_Group_ID}
        OR $P{C_BP_Group_ID} IS NULL)

WHERE
    fa.PostingType = 'A'
    AND fa.Account_ID = $P{Account_ID}
    AND fa.DateAcct <= $P{DateAcct2}
    AND (fa.AD_OrgTrx_ID = $P{AD_Org_ID}
         OR $P{AD_Org_ID} IS NULL)

GROUP BY
    ev.value,
    bp.value,
    bp.name

HAVING
    SUM(
        CASE
            WHEN fa.dateacct <= $P{DateAcct2} THEN
                CASE
                    WHEN ev.accounttype IN ('A','E')
                        THEN fa.amtacctdr - fa.amtacctcr
                    ELSE
                        -(fa.amtacctdr - fa.amtacctcr)
                END
            ELSE 0
        END
    ) <> 0

ORDER BY
    bp.value;]]>
	</queryString>
