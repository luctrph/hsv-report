	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date(122,0,1)]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date(122,11,31)]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="C_ElementValue_ID" class="java.lang.Integer"/>
	<parameter name="C_Activity_ID" class="java.lang.Integer"/>
	<parameter name="C_BPartner_ID" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[WITH DM_Cap1 AS (
    -- Lấy danh sách các tài khoản mẹ (độ dài = 1)
    SELECT ev.value AS dm_value, ev.name AS dm_name, ev.ad_client_id
    FROM c_elementvalue ev 
    WHERE ev.ad_client_id = $P{AD_CLIENT_ID} 
      AND LENGTH(ev.value) = 1
),
PhatSinh AS (
    -- Tính toán số liệu chi tiết từ Fact_Acct
    SELECT 
        c.value AS acc_value, 
        c.name AS acc_name,
        SUM(CASE 
            WHEN LEFT(c.value,1) IN ('1','2','6','8','9') AND t.dateacct < $P{StartDate} THEN (t.amtacctdr - t.amtacctcr)
            WHEN LEFT(c.value,1) IN ('3','4','5','7') AND t.dateacct < $P{StartDate} THEN (t.amtacctcr - t.amtacctdr)
            ELSE 0 END) AS dudau,
        SUM(CASE 
            WHEN t.dateacct >= $P{StartDate} AND t.dateacct <= $P{EndDate} THEN t.amtacctdr 
            ELSE 0 END) AS psno,
        SUM(CASE 
            WHEN t.dateacct >= $P{StartDate} AND t.dateacct <= $P{EndDate} THEN t.amtacctcr 
            ELSE 0 END) AS psco,
        SUM(CASE 
            WHEN LEFT(c.value,1) IN ('1','2','6','8','9') AND t.dateacct <= $P{EndDate} THEN (t.amtacctdr - t.amtacctcr)
            WHEN LEFT(c.value,1) IN ('3','4','5','7') AND t.dateacct <= $P{EndDate} THEN (t.amtacctcr - t.amtacctdr)
            ELSE 0 END) AS ducuoi
    FROM Fact_Acct t
    JOIN c_elementvalue c ON t.account_id = c.c_elementvalue_id 
    WHERE t.AD_Client_ID = $P{AD_CLIENT_ID}
      AND (t.ad_org_id = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
      AND (t.c_activity_id = $P{C_Activity_ID} OR $P{C_Activity_ID} IS NULL)
    GROUP BY c.name, c.value
)
SELECT 
    d.dm_value, 
    d.dm_name, 
    COALESCE(p.acc_value, d.dm_value) as account_value, 
    COALESCE(p.acc_name, d.dm_name) as account_name,
    COALESCE(p.dudau, 0) as dudau, 
    COALESCE(p.psno, 0) as psno, 
    COALESCE(p.psco, 0) as psco, 
    COALESCE(p.ducuoi, 0) as ducuoi
FROM DM_Cap1 d
LEFT JOIN PhatSinh p ON p.acc_value LIKE d.dm_value || '%'
where p.ducuoi <> 0 
ORDER BY d.dm_value, account_value;]]>
	</queryString>
