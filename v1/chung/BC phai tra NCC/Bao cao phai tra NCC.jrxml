	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.2" value="pageFooter"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.3" value="groupHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.remove.empty.space.between.rows" value="true"/>
	<property name="net.sf.jasperreports.export.xlsx.remove.empty.space.between.columns" value="true"/>
	<property name="net.sf.jasperreports.export.xlsx.white.page.background" value="false"/>
	<property name="net.sf.jasperreports.export.xlsx.detect.cell.type" value="true"/>
	<property name="net.sf.jasperreports.export.xlsx.ignore.graphics" value="false"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.band.1" value="pageHeader"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.group.3" value="ProductGroup"/>
	<property name="net.sf.jasperreports.export.xlsx.exclude.origin.report.3" value="ProductReport"/>
	<property name="net.sf.jasperreports.export.xlsx.ignore.cell.border" value="false"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1000006]]></defaultValueExpression>
	</parameter>
	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date(118,0,1)]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="C_BP_Group_ID" class="java.lang.String"/>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT t.nhom, t.value, t.name, t.ducuoi, t.dudau, t.psno, t.psco
FROM (
    SELECT n.name AS nhom, t.value, t.name,
           SUM(t.ducuoi) AS ducuoi,
           SUM(t.dudau)  AS dudau,
           SUM(t.psno)   AS psno,
           SUM(t.psco)   AS psco
    FROM (

        -- [1+5] Hoa don: gop API/ARC (phai tra) va APC/ARI (da tra)
        SELECT bp.C_BP_Group_ID, bp.value, bp.name,
               SUM(CASE WHEN c.DocBaseType IN ('API','ARC') THEN  i.GRANDTOTAL
                        ELSE                                     -i.GRANDTOTAL END)  AS ducuoi,
               COALESCE(SUM(CASE WHEN i.DATEACCT < $P{StartDate}
                                 THEN CASE WHEN c.DocBaseType IN ('API','ARC') THEN  i.GRANDTOTAL
                                           ELSE                                     -i.GRANDTOTAL END
                            END), 0)                                                 AS dudau,
               COALESCE(SUM(CASE WHEN i.DATEACCT >= $P{StartDate} AND i.DATEACCT <= $P{EndDate}
                                  AND c.DocBaseType IN ('API','ARC')
                                 THEN i.GRANDTOTAL END), 0)                          AS psco,
               COALESCE(SUM(CASE WHEN i.DATEACCT >= $P{StartDate} AND i.DATEACCT <= $P{EndDate}
                                  AND c.DocBaseType IN ('APC','ARI')
                                 THEN i.GRANDTOTAL END), 0)                          AS psno
        FROM C_INVOICE i
        INNER JOIN C_DocType c ON c.C_DocType_ID  = i.C_DocType_ID
                               AND c.DocBaseType  IN ('API','ARC','APC','ARI')
        JOIN C_BPARTNER bp     ON i.C_BPARTNER_ID = bp.C_BPARTNER_ID
                               AND bp.AD_Client_ID = $P{AD_CLIENT_ID}
                               AND bp.isVendor     = 'Y'
                               AND ($P{C_BP_Group_ID} IS NULL OR bp.C_BP_Group_ID = ANY(string_to_array($P{C_BP_Group_ID}, ',')::integer[]))
        WHERE i.DATEACCT     <= $P{EndDate}
          AND i.docstatus    IN ('CO','CL')
          AND i.AD_Client_ID  = $P{AD_CLIENT_ID}
          AND (i.C_Currency_ID = $P{C_Currency_ID} OR $P{C_Currency_ID} IS NULL)
        GROUP BY bp.C_BP_Group_ID, bp.value, bp.name

        -- [2+6] Phieu thanh toan: gop ISRECEIPT=Y (thu) va N (chi)
        UNION ALL

        SELECT bp.C_BP_Group_ID, bp.value, bp.name,
               SUM(CASE WHEN p.ISRECEIPT = 'Y' THEN  p.PAYAMT
                        ELSE                        -p.PAYAMT END)                   AS ducuoi,
               COALESCE(SUM(CASE WHEN p.DATEACCT < $P{StartDate}
                                 THEN CASE WHEN p.ISRECEIPT = 'Y' THEN  p.PAYAMT
                                           ELSE                        -p.PAYAMT END
                            END), 0)                                                 AS dudau,
               COALESCE(SUM(CASE WHEN p.DATEACCT >= $P{StartDate} AND p.DATEACCT <= $P{EndDate}
                                  AND p.ISRECEIPT = 'Y'
                                 THEN p.PAYAMT END), 0)                              AS psco,
               COALESCE(SUM(CASE WHEN p.DATEACCT >= $P{StartDate} AND p.DATEACCT <= $P{EndDate}
                                  AND p.ISRECEIPT = 'N'
                                 THEN p.PAYAMT END), 0)                              AS psno
        FROM C_PAYMENT p
        JOIN C_BPARTNER bp     ON p.C_BPARTNER_ID = bp.C_BPARTNER_ID
                               AND bp.AD_Client_ID = $P{AD_CLIENT_ID}
                               AND bp.isVendor     = 'Y'
                                AND ($P{C_BP_Group_ID} IS NULL OR bp.C_BP_Group_ID = ANY(string_to_array($P{C_BP_Group_ID}, ',')::integer[]))
        WHERE p.DATEACCT     <= $P{EndDate}
          AND p.docstatus    IN ('CO','CL')
          AND p.posted        = 'Y'
          AND p.c_charge_id  IS NULL
          AND p.ISRECEIPT    IN ('Y','N')
          AND p.AD_Client_ID  = $P{AD_CLIENT_ID}
          AND (p.C_Currency_ID = $P{C_Currency_ID} OR $P{C_Currency_ID} IS NULL)
        GROUP BY bp.C_BP_Group_ID, bp.value, bp.name

        -- [3+4] Phan bo DUONG (discount + writeoff > 0) tren hoa don ARI/APC
        UNION ALL

        SELECT t.C_BP_Group_ID, t.value, t.name,
               COALESCE(SUM(t.amt), 0)                                                        AS ducuoi,
               COALESCE(SUM(CASE WHEN t.datetrx <  $P{StartDate}               THEN t.amt END), 0) AS dudau,
               COALESCE(SUM(CASE WHEN t.datetrx >= $P{StartDate}
                                  AND t.datetrx <= $P{EndDate}                 THEN t.amt END), 0) AS psco,
               0                                                                               AS psno
        FROM (
            SELECT ca.datetrx,
                   CASE WHEN cal.discountamt > 0 THEN cal.discountamt ELSE 0 END
                 + CASE WHEN cal.writeoffamt  > 0 THEN cal.writeoffamt  ELSE 0 END  AS amt,
                   iv.c_doctype_id,
                   bp.C_BP_Group_ID, bp.value, bp.name
            FROM c_allocationline cal
            INNER JOIN c_allocationhdr ca ON cal.c_allocationhdr_id = ca.c_allocationhdr_id
                                          AND ca.docstatus IN ('CO','CL')
                                          AND ca.datetrx   <= $P{EndDate}
            INNER JOIN c_invoice iv        ON cal.c_invoice_id = iv.c_invoice_id
                                          AND iv.AD_Client_ID  = $P{AD_CLIENT_ID}
                                          AND (iv.C_Currency_ID = $P{C_Currency_ID} OR $P{C_Currency_ID} IS NULL)
            JOIN C_BPARTNER bp             ON cal.C_BPARTNER_ID = bp.C_BPARTNER_ID
                                          AND bp.AD_Client_ID   = $P{AD_CLIENT_ID}
                                          AND bp.isVendor       = 'Y'
                                           AND ($P{C_BP_Group_ID} IS NULL OR bp.C_BP_Group_ID = ANY(string_to_array($P{C_BP_Group_ID}, ',')::integer[]))
            WHERE (cal.discountamt > 0 OR cal.writeoffamt > 0)
              AND cal.c_invoice_id IS NOT NULL
              AND cal.AD_Client_ID  = $P{AD_CLIENT_ID}
        ) AS t
        INNER JOIN c_doctype doc ON t.c_doctype_id  = doc.c_doctype_id
                                 AND doc.docbasetype IN ('ARI','APC')
        GROUP BY t.C_BP_Group_ID, t.value, t.name

        -- [7] Tru di phan bo CMA (charge, khong co invoice)
        UNION ALL

        SELECT t.C_BP_Group_ID, t.value, t.name,
               COALESCE(SUM(t.amount), 0)                                                      AS ducuoi,
               COALESCE(SUM(CASE WHEN t.datetrx <  $P{StartDate}             THEN t.amount END), 0) AS dudau,
               COALESCE(SUM(CASE WHEN t.datetrx >= $P{StartDate}
                                  AND t.datetrx <= $P{EndDate}               THEN t.amount END), 0) AS psco,
               0                                                                               AS psno
        FROM (
            SELECT ca.datetrx, cal.amount, ca.c_doctype_id,
                   bp.C_BP_Group_ID, bp.value, bp.name
            FROM c_allocationline cal
            INNER JOIN c_allocationhdr ca ON cal.c_allocationhdr_id = ca.c_allocationhdr_id
                                          AND ca.docstatus IN ('CO','CL')
                                          AND ca.datetrx   <= $P{EndDate}
                                          AND (ca.C_Currency_ID = $P{C_Currency_ID} OR $P{C_Currency_ID} IS NULL)
            JOIN C_BPARTNER bp             ON cal.C_BPARTNER_ID = bp.C_BPARTNER_ID
                                          AND bp.AD_Client_ID   = $P{AD_CLIENT_ID}
                                          AND bp.isVendor       = 'Y'
                                           AND ($P{C_BP_Group_ID} IS NULL OR bp.C_BP_Group_ID = ANY(string_to_array($P{C_BP_Group_ID}, ',')::integer[]))
            WHERE cal.c_charge_id  IS NOT NULL
              AND cal.c_invoice_id IS NULL
              AND cal.AD_Client_ID  = $P{AD_CLIENT_ID}
        ) AS t
        INNER JOIN c_doctype doc ON t.c_doctype_id  = doc.c_doctype_id
                                 AND doc.docbasetype IN ('CMA')
        GROUP BY t.C_BP_Group_ID, t.value, t.name

        -- [8+9] Phan bo AM (discount + writeoff < 0) tren hoa don API/ARC
        UNION ALL

        SELECT t.C_BP_Group_ID, t.value, t.name,
               COALESCE(SUM(t.amt), 0)                                                        AS ducuoi,
               COALESCE(SUM(CASE WHEN t.datetrx <  $P{StartDate}               THEN t.amt END), 0) AS dudau,
               COALESCE(SUM(CASE WHEN t.datetrx >= $P{StartDate}
                                  AND t.datetrx <= $P{EndDate}                 THEN t.amt END), 0) AS psco,
               0                                                                               AS psno
        FROM (
            SELECT ca.datetrx,
                   CASE WHEN cal.discountamt < 0 THEN cal.discountamt ELSE 0 END
                 + CASE WHEN cal.writeoffamt  < 0 THEN cal.writeoffamt  ELSE 0 END  AS amt,
                   iv.c_doctype_id,
                   bp.C_BP_Group_ID, bp.value, bp.name
            FROM c_allocationline cal
            INNER JOIN c_allocationhdr ca ON cal.c_allocationhdr_id = ca.c_allocationhdr_id
                                          AND ca.docstatus IN ('CO','CL')
                                          AND ca.datetrx   <= $P{EndDate}
            INNER JOIN c_invoice iv        ON cal.c_invoice_id = iv.c_invoice_id
                                          AND iv.AD_Client_ID  = $P{AD_CLIENT_ID}
                                          AND (iv.C_Currency_ID = $P{C_Currency_ID} OR $P{C_Currency_ID} IS NULL)
            JOIN C_BPARTNER bp             ON cal.C_BPARTNER_ID = bp.C_BPARTNER_ID
                                          AND bp.AD_Client_ID   = $P{AD_CLIENT_ID}
                                          AND bp.isVendor       = 'Y'
                                          AND ($P{C_BP_Group_ID} IS NULL OR bp.C_BP_Group_ID = ANY(string_to_array($P{C_BP_Group_ID}, ',')::integer[]))
            WHERE (cal.discountamt < 0 OR cal.writeoffamt < 0)
              AND cal.c_invoice_id IS NOT NULL
              AND cal.AD_Client_ID  = $P{AD_CLIENT_ID}
        ) AS t
        INNER JOIN c_doctype doc ON t.c_doctype_id  = doc.c_doctype_id
                                 AND doc.docbasetype IN ('API','ARC')
        GROUP BY t.C_BP_Group_ID, t.value, t.name

    ) AS t
    JOIN C_BP_Group n ON t.C_BP_Group_ID = n.C_BP_Group_ID
                     AND n.AD_Client_ID  = $P{AD_CLIENT_ID}
    GROUP BY t.C_BP_Group_ID, t.value, t.name, n.name
) AS t
WHERE t.dudau  <> 0 OR t.ducuoi <> 0
   OR t.psno   <> 0 OR t.psco   <> 0
ORDER BY t.nhom, t.ducuoi DESC]]>
	</queryString>
