	<parameter name="AD_CLIENT_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1000006]]></defaultValueExpression>
	</parameter>
	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date(118,0,1)]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="C_BP_Group_ID" class="java.lang.Integer"/>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH filtered_facts AS (
    -- Bước 1: Lấy toàn bộ phát sinh của tài khoản 3311 đến ngày EndDate
    SELECT 
        fa.amtacctdr, 
        fa.amtacctcr, 
        fa.account_id, 
        fa.c_bpartner_id,
        bp.value AS bp_value,
        bp.name AS bp_name,
        cbg.name as group_name,
        fa.dateacct 
    FROM Fact_Acct fa
    INNER JOIN C_ElementValue ev ON fa.account_id = ev.c_elementvalue_id
    LEFT JOIN C_BPartner bp ON fa.c_bpartner_id = bp.c_bpartner_id
    join c_bp_group cbg on bp.c_bp_group_id = cbg.c_bp_group_id 
    WHERE fa.AD_Client_ID = $P{AD_CLIENT_ID}
      AND ev.Value LIKE '331%' 
      AND fa.dateacct <= $P{EndDate} -- Không lấy dữ liệu tương lai
      and fa.c_currency_id = $P{C_Currency_ID}
)
SELECT 
	f.group_name as nhom,
    f.bp_value AS "value",
    f.bp_name AS "name",
    
    -- Số dư đầu kỳ: Tổng Có - Tổng Nợ của tất cả phát sinh TRƯỚC ngày StartDate
    SUM(CASE WHEN f.dateacct < $P{StartDate} THEN (f.amtacctcr - f.amtacctdr) ELSE 0 END) AS "dudau",
    
    -- Phát sinh Nợ: Các khoản thanh toán, giảm trừ nợ trong kỳ
    SUM(CASE WHEN f.dateacct >= $P{StartDate} AND f.dateacct <= $P{EndDate} THEN f.amtacctdr ELSE 0 END) AS "psno",
    
    -- Phát sinh Có: Các khoản mua hàng, tăng nợ trong kỳ
    SUM(CASE WHEN f.dateacct >= $P{StartDate} AND f.dateacct <= $P{EndDate} THEN f.amtacctcr ELSE 0 END) AS "psco",
    
    -- Số dư cuối kỳ: (Dư đầu Có + PS Có) - PS Nợ
    SUM(f.amtacctcr - f.amtacctdr) AS "ducuoi"

FROM filtered_facts f
GROUP BY f.bp_value, f.bp_name,f.group_name
-- Chỉ hiển thị những đối tác có phát sinh hoặc có số dư
HAVING 
    SUM(f.amtacctcr - f.amtacctdr) <> 0 OR 
    SUM(CASE WHEN f.dateacct >= $P{StartDate} AND f.dateacct <= $P{EndDate} THEN f.amtacctdr ELSE 0 END) <> 0 OR
    SUM(CASE WHEN f.dateacct >= $P{StartDate} AND f.dateacct <= $P{EndDate} THEN f.amtacctcr ELSE 0 END) <> 0 or 
    SUM(f.amtacctcr - f.amtacctdr) <> 0
ORDER BY f.group_name,f.bp_value;]]>
	</queryString>
