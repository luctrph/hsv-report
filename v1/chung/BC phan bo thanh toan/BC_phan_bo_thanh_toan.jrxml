<!-- Created with Jaspersoft Studio version 6.20.0.final using JasperReports Library version 6.20.0-2bc7ab61c56f459e8176eb05c7705e145cd400ad  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="BC_phan_bo_thanh_toan" pageWidth="650" pageHeight="842" columnWidth="610" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f011ac7b-5235-4ff5-be00-d97a53621ee6">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="psql"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<style name="Style1" mode="Opaque" backcolor="rgba(255, 255, 255, 0.0)">
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{note}==true]]></conditionExpression>
			<style mode="Opaque" backcolor="#A8FFD5"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{note}==false]]></conditionExpression>
			<style/>
		</conditionalStyle>
	</style>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    k.value,
    k.name,
    cc.iso_code,

    -- Số dư chưa phân bổ (Tổng - Đã phân bổ)
    SUM(thu_total - thu_alloc) AS thu,
    SUM(chi_total - chi_alloc) AS chi,
    SUM(ban_total - ban_paid)  AS ban,
    SUM(mua_total - mua_paid)  AS mua,

    CASE
        -- 1. THU đối ứng với BÁN (Thông thường)
        WHEN SUM(thu_total - thu_alloc) = SUM(ban_total - ban_paid) 
             AND SUM(thu_total - thu_alloc) <> 0 THEN TRUE
        
        -- 2. CHI đối ứng với MUA (Thông thường)
        WHEN SUM(chi_total - chi_alloc) = SUM(mua_total - mua_paid) 
             AND SUM(chi_total - chi_alloc) <> 0 THEN TRUE

        -- 3. HÓA ĐƠN NGƯỢC VẾ: BÁN đối ứng với CHI
        WHEN SUM(ban_total - ban_paid) = SUM(chi_total - chi_alloc) 
             AND SUM(ban_total - ban_paid) <> 0 THEN TRUE

        -- 4. HÓA ĐƠN NGƯỢC VẾ: MUA đối ứng với THU
        WHEN SUM(mua_total - mua_paid) = SUM(thu_total - thu_alloc) 
             AND SUM(mua_total - mua_paid) <> 0 THEN TRUE

        ELSE FALSE
    END AS note
FROM (
    /* ================= PAYMENT ================= */
    SELECT
        cb.value,
        cb.name,
        SUM(CASE WHEN pay.isreceipt='Y' THEN pay.payamt ELSE 0 END) AS thu_total,
        SUM(CASE WHEN pay.isreceipt='Y' AND pay.isallocated='Y' THEN pay.payamt ELSE 0 END) AS thu_alloc,
        SUM(CASE WHEN pay.isreceipt='N' THEN pay.payamt ELSE 0 END) AS chi_total,
        SUM(CASE WHEN pay.isreceipt='N' AND pay.isallocated='Y' THEN pay.payamt ELSE 0 END) AS chi_alloc,
        0 AS ban_total, 0 AS ban_paid, 0 AS mua_total, 0 AS mua_paid
    FROM c_payment pay
    JOIN c_bpartner cb ON cb.c_bpartner_id = pay.c_bpartner_id
    WHERE pay.ad_client_id = $P{AD_CLIENT_ID}
      AND pay.docstatus IN ('CL','CO')
      AND pay.c_currency_id = $P{C_Currency_ID} 
    GROUP BY cb.value, cb.name

    UNION ALL

    /* ================= INVOICE ================= */
    SELECT
        cb.value,
        cb.name,
        0 AS thu_total, 0 AS thu_alloc, 0 AS chi_total, 0 AS chi_alloc,
        SUM(CASE WHEN ci.issotrx='Y' THEN ci.grandtotal ELSE 0 END) AS ban_total,
        SUM(CASE WHEN ci.issotrx='Y' AND ci.ispaid='Y' THEN ci.grandtotal ELSE 0 END) AS ban_paid,
        SUM(CASE WHEN ci.issotrx='N' THEN ci.grandtotal ELSE 0 END) AS mua_total,
        SUM(CASE WHEN ci.issotrx='N' AND ci.ispaid='Y' THEN ci.grandtotal ELSE 0 END) AS mua_paid
    FROM c_invoice ci
    JOIN c_bpartner cb ON cb.c_bpartner_id = ci.c_bpartner_id
    WHERE ci.ad_client_id = $P{AD_CLIENT_ID}
      AND ci.c_currency_id = $P{C_Currency_ID}
      AND ci.docstatus IN ('CL','CO')
    GROUP BY cb.value, cb.name
) k
LEFT JOIN c_currency cc ON cc.c_currency_id = $P{C_Currency_ID}
GROUP BY k.value, k.name, cc.iso_code
HAVING 
    -- Giữ nguyên bộ lọc để chỉ hiện những dòng có phát sinh chưa khớp
    SUM(thu_total - thu_alloc) <> 0 
    OR SUM(chi_total - chi_alloc) <> 0
    OR SUM(ban_total - ban_paid) <> 0
    OR SUM(mua_total - mua_paid) <> 0

ORDER BY k.name;]]>
	</queryString>
