	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date(119,0,1)]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="Account_ID" class="java.lang.Integer"/>
	<parameter name="EXPORT_TYPE" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[WITH fact_data AS (
    -- Part 1: Các bút toán KHÔNG phải GL Journal (ad_table_id <> 224)
    SELECT
        fa.dateacct,
        fa.amtacctdr,
        fa.amtacctcr,
        fa.account_id,
        fa.description
    FROM fact_acct fa
    WHERE fa.dateacct          <= $P{EndDate}
      AND fa.ad_client_id       = $P{AD_CLIENT_ID}
     
      AND fa.ad_table_id       <> 224
      AND (fa.ad_org_id         = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
      AND (fa.account_id        = $P{Account_ID} OR $P{Account_ID} IS NULL)

    UNION ALL

    -- Part 2: GL Journal — dòng nhập tay (IsGenerated='N'), có line_id
    SELECT
        fa.dateacct,
        fa.amtacctdr,
        fa.amtacctcr,
        fa.account_id,
        fa.description
    FROM fact_acct fa
    JOIN gl_journalline gl ON fa.record_id  = gl.gl_journal_id
                          AND fa.line_id    = gl.gl_journalline_id
                          AND fa.account_id = gl.account_id
                          AND gl.isgenerated = 'N'
    JOIN gl_journal     a  ON a.gl_journal_id = fa.record_id
                          AND a.docstatus IN ('CO', 'CL')
    WHERE fa.dateacct          <= $P{EndDate}
      AND fa.ad_client_id       = $P{AD_CLIENT_ID}
    
      AND fa.ad_table_id        = 224
      AND fa.line_id            IS NOT NULL           -- đảm bảo không chồng Part 3
      AND (fa.ad_orgtrx_id      = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
      AND (fa.account_id        = $P{Account_ID} OR $P{Account_ID} IS NULL)

    UNION ALL

    -- Part 3: GL Journal — dòng không có line (line_id IS NULL)
    SELECT
        fa.dateacct,
        fa.amtacctdr,
        fa.amtacctcr,
        fa.account_id,
        fa.description
    FROM fact_acct fa
    JOIN gl_journal a ON a.gl_journal_id = fa.record_id
                     AND a.docstatus IN ('CO', 'CL')
    WHERE fa.dateacct          <= $P{EndDate}
      AND fa.ad_client_id       = $P{AD_CLIENT_ID}
     
      AND fa.ad_table_id        = 224
      AND fa.line_id            IS NULL               -- chỉ lấy dòng không có line
      AND (fa.ad_orgtrx_id      = $P{AD_Org_ID} OR $P{AD_Org_ID} IS NULL)
      AND (fa.account_id        = $P{Account_ID} OR $P{Account_ID} IS NULL)
),

account_detail AS (
    SELECT
        ev.value  AS accountvalue,
        ev.name   AS accountname,
        ROUND(SUM(CASE
            WHEN t.dateacct < $P{StartDate}
             AND ev.accountsign IN ('D','N')
            THEN (t.amtacctdr - t.amtacctcr)
            ELSE 0
        END), 0)  AS dudauno,
        ROUND(SUM(CASE
            WHEN t.dateacct < $P{StartDate}
             AND ev.accountsign = 'C'
            THEN -1 * (t.amtacctdr - t.amtacctcr)
            ELSE 0
        END), 0)  AS dudauco,
        ROUND(SUM(CASE
            WHEN t.dateacct >= $P{StartDate}
             AND t.dateacct  <= $P{EndDate}
            THEN t.amtacctdr
            ELSE 0
        END), 0)  AS psno,
        ROUND(SUM(CASE
            WHEN t.dateacct >= $P{StartDate}
             AND t.dateacct  <= $P{EndDate}
            THEN t.amtacctcr
            ELSE 0
        END), 0)  AS psco,
        ROUND(SUM(CASE
            WHEN t.dateacct <= $P{EndDate}
             AND ev.accountsign IN ('D','N')
            THEN (t.amtacctdr - t.amtacctcr)
            ELSE 0
        END), 0)  AS ducuoino,
        ROUND(SUM(CASE
            WHEN t.dateacct <= $P{EndDate}
             AND ev.accountsign = 'C'
            THEN -1 * (t.amtacctdr - t.amtacctcr)
            ELSE 0
        END), 0)  AS ducuoico
    FROM fact_data t
    JOIN c_elementvalue ev ON t.account_id = ev.c_elementvalue_id
    GROUP BY ev.value, ev.name
    -- ✅ Đã bỏ ORDER BY ở đây — vô nghĩa trong subquery/CTE
)

SELECT
    tk.value,
    tk.name,
    cd.accountvalue,
    cd.accountname,
    SUM(cd.dudauno)   AS dudauno,
    SUM(cd.dudauco)   AS dudauco,
    SUM(cd.psno)      AS psno,
    SUM(cd.psco)      AS psco,
    SUM(cd.ducuoino)  AS ducuoino,
    SUM(cd.ducuoico)  AS ducuoico
FROM account_detail cd
LEFT JOIN c_elementvalue tk
       ON LEFT(cd.accountvalue, 3) = tk.value
      AND tk.ad_client_id = $P{AD_CLIENT_ID}  -- ✅ Đã thêm filter client
GROUP BY tk.value, tk.name, cd.accountvalue, cd.accountname
ORDER BY cd.accountvalue                       -- ✅ ORDER BY chuyển ra ngoài cùng]]>
	</queryString>
