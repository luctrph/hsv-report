	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="StartDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date(100,0,1)]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<defaultValueExpression><![CDATA[new Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="C_AcctSchema_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[new Integer("1000000")]]></defaultValueExpression>
	</parameter>
	<parameter name="AD_Org_ID" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="Account_ID" class="java.lang.Integer"/>
	<parameter name="EXPORT_TYPE" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[select tk.value,tk.name,cd.accountvalue,cd.Accountname,sum(cd.dudauno) as dudauno,sum(cd.dudauco) as dudauco,sum(cd.psno) as psno,sum(cd.psco) as psco,sum(cd.ducuoino) as ducuoino,sum(cd.ducuoico) as ducuoico 
from   
  (select c_elementvalue.value as Accountvalue,c_elementvalue.name as Accountname,

	round(sum(	CASE WHEN t.dateacct < $P{StartDate} and  c_elementvalue.accountsign in ('D','N')THEN (t.amtacctdr-t.amtacctcr)
			ELSE 0
		END),0) as dudauno,

	round(sum(	CASE WHEN t.dateacct < $P{StartDate} and c_elementvalue.accountsign in ('C')THEN -1*(t.amtacctdr-t.amtacctcr)
			ELSE 0
		END),0) as dudauco,

	round(sum(	CASE WHEN t.dateacct >= $P{StartDate}AND t.dateacct <= $P{EndDate} THEN (t.amtacctdr ) 
			ELSE 0
		END),0) as psno,

	round(sum(	CASE WHEN t.dateacct >= $P{StartDate} AND t.dateacct <= $P{EndDate} THEN (t.amtacctcr)
			ELSE 0
		END),0) as psco,

	round(sum(CASE WHEN t.dateacct <= $P{EndDate} and c_elementvalue.accountsign in ('D','N') THEN (t.amtacctdr-t.amtacctcr) ELSE 0 END),0)as ducuoino ,

	round(sum(CASE WHEN t.dateacct <= $P{EndDate} and c_elementvalue.accountsign in ('C') THEN -1*(t.amtacctdr-t.amtacctcr) ELSE 0 END),0)as ducuoico 
  from 

	(       SELECT Fact_Acct.dateacct,Fact_Acct.amtacctdr,Fact_Acct.amtacctcr,Fact_Acct.account_id,Fact_Acct.description 
          	FROM Fact_Acct 
          	WHERE  
                  Fact_Acct.dateacct<=$P{EndDate}
          				and  Fact_Acct.AD_Client_ID=$P{AD_CLIENT_ID}
          				and 	Fact_Acct.C_AcctSchema_ID=$P{C_AcctSchema_ID} 
          				and  (Fact_Acct.AD_org_id=$P{AD_Org_ID} or $P{AD_Org_ID} is null)
        		  		and (Fact_Acct.Account_ID=$P{Account_ID} or $P{Account_ID} is null)
           				and Fact_Acct.ad_table_id<>224	
	
			union all
					 
      	 	SELECT Fact_Acct.dateacct,Fact_Acct.amtacctdr,Fact_Acct.amtacctcr,Fact_Acct.account_id ,Fact_Acct.description
      	   FROM Fact_Acct 
            join gl_journalline gl on  Fact_Acct.record_id=gl.gl_journal_id
                  and Fact_Acct.line_id=gl.gl_journalline_id and Fact_Acct.Account_ID=gl.Account_ID  and gl.IsGenerated='N'
            join gl_journal a on a.gl_journal_id =Fact_Acct.record_id and a.docstatus in ('CO','CL')	
      		WHERE  
      				Fact_Acct.dateacct<=$P{EndDate}and  Fact_Acct.AD_Client_ID=$P{AD_CLIENT_ID}
          				 and Fact_Acct.C_AcctSchema_ID=$P{C_AcctSchema_ID} 
          				 and (Fact_Acct.Account_ID=$P{Account_ID} or $P{Account_ID} is null)
      	 			     and  (Fact_Acct.AD_orgtrx_id=$P{AD_Org_ID} or $P{AD_Org_ID} is null)
          	 			 and Fact_Acct.ad_table_id=224
      	 union all
	 
      	 SELECT Fact_Acct.dateacct,Fact_Acct.amtacctdr,Fact_Acct.amtacctcr,Fact_Acct.account_id ,Fact_Acct.description 
      	     FROM Fact_Acct 
              join gl_journal a on a.gl_journal_id =Fact_Acct.record_id and a.docstatus in ('CO','CL')	
       	 WHERE  
      				Fact_Acct.dateacct<=$P{EndDate}and  Fact_Acct.AD_Client_ID=$P{AD_CLIENT_ID}and Fact_Acct.ad_table_id=224
      			 	  and Fact_Acct.C_AcctSchema_ID=$P{C_AcctSchema_ID} 
      		  		and (Fact_Acct.Account_ID=$P{Account_ID} or $P{Account_ID} is null)
      	   			and  (Fact_Acct.AD_orgtrx_id=$P{AD_Org_ID} or $P{AD_Org_ID} is null)
        	 			and Fact_Acct.line_id is null
	 ) as t
  inner join c_elementvalue 	on t.account_id=c_elementvalue.c_elementvalue_id 
  group by  c_elementvalue.value ,c_elementvalue.name 
  order by c_elementvalue.value) as cd 
left join c_elementvalue tk on left(cd.accountvalue,3)=tk.value and tk.AD_Client_ID=$P{AD_CLIENT_ID}
group by tk.value,tk.name,cd.accountvalue,cd.Accountname]]>
	</queryString>
