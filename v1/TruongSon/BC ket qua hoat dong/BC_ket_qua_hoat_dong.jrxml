	</field>
	<field name="ps" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="ps"/>
		<property name="com.jaspersoft.studio.field.label" value="ps"/>
	</field>
	<field name="qty" class="java.math.BigDecimal">
