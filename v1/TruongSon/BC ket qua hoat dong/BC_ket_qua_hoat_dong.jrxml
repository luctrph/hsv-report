<!-- Created with Jaspersoft Studio version 6.20.0.final using JasperReports Library version 6.20.0-2bc7ab61c56f459e8176eb05c7705e145cd400ad  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="BC_ket_qua_hoat_dong" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="71aac664-fd71-449b-a696-c395530b7dba">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="psql"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="StartDate" class="java.util.Date"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="EndDate" class="java.util.Date"/>
	<parameter name="check" class="java.lang.String"/>
	<queryString>
		<![CDATA[WITH base AS (
    SELECT fc.amtacctdr, fc.amtacctcr, fc.m_product_id,
           fc.account_id, fc.qty
    FROM fact_acct fc
    JOIN gl_journalline gl ON  fc.record_id  = gl.gl_journal_id
                           AND fc.line_id    = gl.gl_journalline_id
                           AND fc.account_id = gl.account_id
                           AND gl.isgenerated = 'N'
    JOIN gl_journal a      ON  a.gl_journal_id = fc.record_id
                           AND a.docstatus IN ('CO', 'CL')
    WHERE fc.ad_client_id = $P{AD_CLIENT_ID}
      AND fc.ad_table_id  = 224
      AND fc.dateacct BETWEEN $P{StartDate} AND $P{EndDate}

    UNION ALL

    SELECT fc.amtacctdr, fc.amtacctcr, fc.m_product_id,
           fc.account_id, fc.qty
    FROM fact_acct fc
    WHERE fc.ad_client_id = $P{AD_CLIENT_ID}
      AND fc.ad_table_id <> 224
      AND fc.dateacct BETWEEN $P{StartDate} AND $P{EndDate}
),

-- ============================================================
-- MAP tài khoản chi phí
-- ============================================================
acct_map (acct_prefix, id, danhmuc) AS (
    values
    	
        ('621', 1, 'Chi phí Tài khoản nguyên vật liệu (621)'),
        ('622', 2, 'Chi phí Tài khoản nhân công 622'),
        ('623', 3, 'Chi phí tài khoản Quản lý p xưởng 623-628'),
        ('624', 3, 'Chi phí tài khoản Quản lý p xưởng 623-628'),
        ('625', 3, 'Chi phí tài khoản Quản lý p xưởng 623-628'),
        ('626', 3, 'Chi phí tài khoản Quản lý p xưởng 623-628'),
        ('627', 3, 'Chi phí tài khoản Quản lý p xưởng 623-628'),
        ('628', 3, 'Chi phí tài khoản Quản lý p xưởng 623-628'),
        ('632', 4, 'Chi phí bù trừ giá hạch toán tồn kho (632)'),
        ('635', 5, 'Chi phí tài chính 635' ),
        ('641', 6, 'Chi phí bán hàng 641'),
        ('642', 7, 'Chi phí tài khoản chi phí quản lý …642'),
        ('811', 8, 'Chi phí khác 811')
),

-- ============================================================
-- A1. Doanh Thu bán hàng (511)
-- ============================================================
dt_511 AS (
    SELECT
        'A'                              AS section,
        'Doanh thu'                      AS section_name,
        1                                AS id,
        'Doanh Thu bán hàng (511)'       AS danhmuc,
        
        coalesce(CASE WHEN $P{check} = 'Y' THEN p.name ELSE pc.name end,acct.name || ' - ' || acct.value) AS product_name,
        coalesce(CASE WHEN $P{check} = 'Y' THEN p.name ELSE pc.name end,acct.value) AS value,
        SUM(fc.amtacctdr)                AS ps_no,
        SUM(fc.amtacctcr)                AS ps_co,
        SUM(fc.amtacctcr - fc.amtacctdr) AS ps,
        -SUM(fc.qty)                     AS qty
    FROM fact_acct fc
    JOIN c_elementvalue     acct ON acct.c_elementvalue_id = fc.account_id
                                AND acct.value LIKE '511%'
    JOIN c_invoice          inv  ON inv.c_invoice_id = fc.record_id
                                AND inv.issotrx      = 'Y'
                                AND inv.docstatus   IN ('CO', 'CL')
    left JOIN m_product          p    ON p.m_product_id  = fc.m_product_id
    left JOIN m_product_category pc   ON pc.m_product_category_id = p.m_product_category_id
    WHERE fc.ad_client_id = $P{AD_CLIENT_ID}
      AND fc.dateacct BETWEEN $P{StartDate} AND $P{EndDate}
    GROUP BY
        acct.c_elementvalue_id, acct.name, acct.value,
        p.m_product_id,           p.name,       -- group cả hai để tránh lỗi Jasper
        pc.m_product_category_id, pc.name
),

-- ============================================================
-- A2. Thu nhập khác (711)
-- ============================================================
dt_711 AS (
    SELECT
        'A'                              AS section,
        'Doanh thu'                      AS section_name,
        2                                AS id,
        'Thu nhập khác (7111)'           AS danhmuc,
        
       acct.name || ' - ' || acct.value AS product_name,
       acct.value as value,
        SUM(t.amtacctdr)                 AS ps_no,
        SUM(t.amtacctcr)                 AS ps_co,
        SUM(t.amtacctcr - t.amtacctdr)  AS ps,
        -SUM(t.qty)                      AS qty
    FROM base t
    JOIN c_elementvalue acct ON acct.c_elementvalue_id = t.account_id
                             AND acct.value LIKE '711%'
    GROUP BY
        acct.c_elementvalue_id, acct.name, acct.value
),

-- ============================================================
-- B. Chi Phí (621–811)
-- ============================================================
chi_phi AS (
    SELECT
        'B'                              AS section,
        'Chi phí'                        AS section_name,
        m.id                             AS id,
        m.danhmuc                        AS danhmuc,
        acct.name || ' - ' || acct.value AS product_name,
        acct.value as value,
        SUM(t.amtacctdr)                 AS ps_no,
        SUM(t.amtacctcr)                 AS ps_co,
        SUM(t.amtacctdr - t.amtacctcr)  AS ps,
        SUM(t.qty)                       AS qty
    FROM base t
    JOIN c_elementvalue     acct ON acct.c_elementvalue_id = t.account_id
    JOIN acct_map           m    ON m.acct_prefix = LEFT(acct.value, 3)
    GROUP BY
        m.id, m.danhmuc,
        acct.name, acct.value

),

-- ============================================================
-- UNION tất cả trước khi gộp
-- ============================================================
all_data AS (
    SELECT * FROM dt_511
    UNION ALL
    SELECT * FROM dt_711
    UNION ALL
    SELECT * FROM chi_phi
)

-- ============================================================
-- FINAL: Gộp lại (cần SUM vì GROUP BY cả product lẫn category)
-- ============================================================
SELECT
    section,                            -- ✅ thêm vào SELECT để ORDER BY an toàn
    section_name,
    id,
    danhmuc, 
    product_name,
    SUM(ps_no) AS ps_no,
    SUM(ps_co) AS ps_co,
    SUM(ps)    AS ps,
    SUM(qty)   AS qty
FROM all_data
GROUP BY section, section_name, id, danhmuc,value, product_name,ps
ORDER BY
    section,
    id,
    CASE WHEN section = 'B' THEN value END ASC,
    CASE WHEN section = 'A' THEN ps  END DESC;]]>
	</queryString>
