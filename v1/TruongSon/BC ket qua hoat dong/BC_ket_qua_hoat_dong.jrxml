	</field>
	<variable name="sum_ps_no" class="java.lang.Double" resetType="Group" resetGroup="Group2" calculation="Sum">
		<variableExpression><![CDATA[$F{ps_no}]]></variableExpression>
	</variable>
	<variable name="sum_ps_co" class="java.lang.Double" resetType="Group" resetGroup="Group2" calculation="Sum">
		<variableExpression><![CDATA[$F{ps_co}]]></variableExpression>
	</variable>
	<variable name="sum_ps" class="java.lang.Double" resetType="Group" resetGroup="Group2" calculation="Sum">
		<variableExpression><![CDATA[$F{ps}]]></variableExpression>
	</variable>
	<variable name="sum_qty" class="java.lang.Double" resetType="Group" resetGroup="Group2" calculation="Sum">
		<variableExpression><![CDATA[$F{qty}]]></variableExpression>
	</variable>
	<variable name="sum_ps_no_1" class="java.lang.Double" resetType="Group" resetGroup="Group1" calculation="Sum">
		<variableExpression><![CDATA[$F{ps_no}]]></variableExpression>
	</variable>
	<variable name="sum_ps_co_1" class="java.lang.Double" resetType="Group" resetGroup="Group1" calculation="Sum">
		<variableExpression><![CDATA[$F{ps_co}]]></variableExpression>
	</variable>
	<variable name="sum_ps_1" class="java.lang.Double" resetType="Group" resetGroup="Group1" calculation="Sum">
		<variableExpression><![CDATA[$F{ps}]]></variableExpression>
	</variable>
	<variable name="sum_qty_1" class="java.lang.Double" resetType="Group" resetGroup="Group1" calculation="Sum">
		<variableExpression><![CDATA[$F{qty}]]></variableExpression>
	</variable>
	<variable name="doanhthu" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{section}.equals("A")?$F{ps}:0]]></variableExpression>
	</variable>
	<variable name="chiphi" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{section}.equals("B")?$F{ps}:0]]></variableExpression>
		<initialValueExpression><![CDATA[new Double(0)]]></initialValueExpression>
	</variable>
