	<parameter name="AD_CLIENT_ID" class="java.lang.Integer"/>
	<parameter name="EndDate" class="java.util.Date"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String">
		<defaultValueExpression><![CDATA["dev/"]]></defaultValueExpression>
	</parameter>
	<parameter name="C_Currency_ID" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[with thongtin as (
    select 
        ci.c_bpartner_id,
        cb.name as doitac,
        cc.iso_code,
        sum(case when cd.docbasetype = 'ARI' then ci.grandtotal else -1 * ci.grandtotal end) as tong_hoadon,
        sum(case when cd.docbasetype = 'ARI' then ci.grandtotal - coalesce(tdtt.da_tt, 0)
                 else -1 * ci.grandtotal - coalesce(tdtt.da_tt, 0) end) as tien_chua_tt
       
    from c_invoice ci
    left join c_order co on co.c_order_id = ci.c_order_id
    join c_bpartner cb on cb.c_bpartner_id = ci.c_bpartner_id
    join c_currency cc on cc.c_currency_id = ci.c_currency_id
    join c_doctype cd on cd.c_doctype_id = ci.c_doctype_id
    left join c_invoicepayschedule sche on sche.c_invoice_id = ci.c_invoice_id
    left join (
        select ca.c_invoice_id, sum(ca.amount + ca.discountamt + ca.writeoffamt) as da_tt
        from c_allocationline ca
        where ca.ad_client_id = $P{AD_CLIENT_ID}
        group by ca.c_invoice_id
    ) tdtt on tdtt.c_invoice_id = ci.c_invoice_id
    where ci.ad_client_id = $P{AD_CLIENT_ID}
      and ci.docstatus in ('CL', 'CO')
      and ci.ispaid = 'N'
      and ci.issotrx = 'Y'
      and ci.c_currency_id = $P{C_Currency_ID}
      and ci.dateacct <= $P{EndDate}
    group by ci.c_bpartner_id, cb.name, cc.iso_code
),
tien_chua_phan_bo as (
    select c_bpartner_id, sum(tt) as c_phanbo
    from (
        select cp.c_bpartner_id, -1 * sum(coalesce(ca.amount, 0)) as tt
        from c_payment cp
        join c_allocationline ca on ca.c_payment_id = cp.c_payment_id 
            and cp.c_bpartner_id = ca.c_bpartner_id
        where cp.ad_client_id = $P{AD_CLIENT_ID}
          and cp.IsAllocated = 'N'
          and cp.docstatus in ('CL', 'CO')
          and cp.c_currency_id = $P{C_Currency_ID}
        group by cp.c_bpartner_id
        union all
        select cp.c_bpartner_id, sum(cp.payamt) as tt
        from c_payment cp
        where cp.ad_client_id = $P{AD_CLIENT_ID}
          and cp.IsAllocated = 'N'
          and cp.docstatus in ('CL', 'CO')
          and cp.c_currency_id = $P{C_Currency_ID}
        group by cp.c_bpartner_id
    ) k
    group by c_bpartner_id
)
select
    row_number() over (order by tt.doitac) as stt,
    tt.doitac,
    tt.iso_code,
    tt.tong_hoadon,
    coalesce(tcpb.c_phanbo, 0) as tien_ve_chua_phan_bo,
    tt.tien_chua_tt,
    tt.tien_chua_tt - coalesce(tcpb.c_phanbo, 0) as cong_no_chua_thanh_toan
from thongtin tt
left join tien_chua_phan_bo tcpb on tt.c_bpartner_id = tcpb.c_bpartner_id
order by cong_no_chua_thanh_toan desc]]>
	</queryString>
